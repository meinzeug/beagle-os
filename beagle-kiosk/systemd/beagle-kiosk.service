# Beagle OS Gaming Kiosk - (c) Dennis Wicht / meinzeug - MIT Licensed
[Unit]
Description=Beagle OS Gaming Kiosk service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/beagle-kiosk
ExecStart=/opt/beagle-kiosk/launch.sh
Restart=always
RestartSec=3

[Install]
WantedBy=beagle-kiosk.target
