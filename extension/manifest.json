{
  "manifest_version": 3,
  "name": "Beagle OS Integration",
  "version": "5.0.4",
  "description": "Adds Beagle profile, installer and control-plane actions to Proxmox VE VM pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "beagle-os@meinzeug"
    }
  }
}
