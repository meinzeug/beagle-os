{
  "manifest_version": 3,
  "name": "Beagle OS Integration",
  "version": "6.6.7",
  "description": "Adds Beagle profile, installer and control-plane actions to Proxmox VE VM pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": [
        "common.js",
        "provider-registry.js",
        "providers/proxmox.js",
        "services/virtualization.js",
        "services/platform.js",
        "shared/vm-profile-mapper.js",
        "shared/vm-profile-helpers.js",
        "services/profile.js",
        "components/profile-modal.js",
        "components/vm-page-integration.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "beagle-os@beagle-os.com"
    }
  }
}
