#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/etc/beagle-os"
ENDPOINT_FILE="$STATE_DIR/endpoint.env"
WRITE_CONFIG="/usr/local/lib/pve-thin-client/installer/write-config.sh"
RUNTIME_USER="thinclient"
AUTOSTART=""
PROFILE_NAME="default"
BEAGLE_STREAM_CLIENT_HOST=""
BEAGLE_STREAM_CLIENT_LOCAL_HOST=""
BEAGLE_STREAM_CLIENT_PORT=""
BEAGLE_STREAM_CLIENT_APP="Desktop"
BEAGLE_STREAM_CLIENT_RESOLUTION="auto"
BEAGLE_STREAM_CLIENT_FPS="60"
BEAGLE_STREAM_CLIENT_BITRATE="20000"
BEAGLE_STREAM_CLIENT_VIDEO_CODEC="H.264"
BEAGLE_STREAM_CLIENT_VIDEO_DECODER="auto"
BEAGLE_STREAM_CLIENT_AUDIO_CONFIG="stereo"
BEAGLE_STREAM_CLIENT_ABSOLUTE_MOUSE="1"
BEAGLE_STREAM_CLIENT_QUIT_AFTER="0"
BEAGLE_STREAM_SERVER_API_URL=""
BEAGLE_STREAM_SERVER_USERNAME=""
BEAGLE_STREAM_SERVER_PASSWORD=""
BEAGLE_STREAM_SERVER_PINNED_PUBKEY=""
BEAGLE_STREAM_SERVER_NAME=""
BEAGLE_STREAM_SERVER_STREAM_PORT=""
BEAGLE_STREAM_SERVER_UNIQUEID=""
BEAGLE_STREAM_SERVER_CERT_B64=""
BEAGLE_HOST=""
BEAGLE_PORT="8006"
BEAGLE_NODE=""
BEAGLE_VMID=""
BEAGLE_REALM="pam"
BEAGLE_VERIFY_TLS="1"
BEAGLE_MANAGER_TOKEN=""
BEAGLE_EGRESS_MODE="direct"
BEAGLE_EGRESS_TYPE=""
BEAGLE_EGRESS_INTERFACE="beagle-egress"
BEAGLE_EGRESS_DOMAINS=""
BEAGLE_EGRESS_RESOLVERS="1.1.1.1 8.8.8.8"
BEAGLE_EGRESS_ALLOWED_IPS=""
BEAGLE_EGRESS_WG_PRIVATE_KEY=""
BEAGLE_EGRESS_WG_ADDRESS=""
BEAGLE_EGRESS_WG_DNS=""
BEAGLE_EGRESS_WG_PUBLIC_KEY=""
BEAGLE_EGRESS_WG_ENDPOINT=""
BEAGLE_EGRESS_WG_PRESHARED_KEY=""
BEAGLE_EGRESS_WG_PERSISTENT_KEEPALIVE="25"
IDENTITY_HOSTNAME=""
IDENTITY_TIMEZONE=""
IDENTITY_LOCALE=""
IDENTITY_KEYMAP=""
IDENTITY_CHROME_PROFILE="default"
NETWORK_MODE="dhcp"
NETWORK_INTERFACE=""
NETWORK_STATIC_ADDRESS=""
NETWORK_STATIC_PREFIX="24"
NETWORK_GATEWAY=""
NETWORK_DNS_SERVERS="1.1.1.1 8.8.8.8"

if [[ -r "$ENDPOINT_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENDPOINT_FILE"
  AUTOSTART="${BEAGLE_ENDPOINT_AUTOSTART:-$AUTOSTART}"
  PROFILE_NAME="${BEAGLE_ENDPOINT_PROFILE_NAME:-$PROFILE_NAME}"
  BEAGLE_STREAM_CLIENT_HOST="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_HOST:-$BEAGLE_STREAM_CLIENT_HOST}"
  BEAGLE_STREAM_CLIENT_LOCAL_HOST="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_LOCAL_HOST:-$BEAGLE_STREAM_CLIENT_LOCAL_HOST}"
  BEAGLE_STREAM_CLIENT_PORT="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_PORT:-$BEAGLE_STREAM_CLIENT_PORT}"
  BEAGLE_STREAM_CLIENT_APP="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_APP:-$BEAGLE_STREAM_CLIENT_APP}"
  BEAGLE_STREAM_CLIENT_RESOLUTION="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_RESOLUTION:-$BEAGLE_STREAM_CLIENT_RESOLUTION}"
  BEAGLE_STREAM_CLIENT_FPS="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_FPS:-$BEAGLE_STREAM_CLIENT_FPS}"
  BEAGLE_STREAM_CLIENT_BITRATE="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_BITRATE:-$BEAGLE_STREAM_CLIENT_BITRATE}"
  BEAGLE_STREAM_CLIENT_VIDEO_CODEC="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_VIDEO_CODEC:-$BEAGLE_STREAM_CLIENT_VIDEO_CODEC}"
  BEAGLE_STREAM_CLIENT_VIDEO_DECODER="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_VIDEO_DECODER:-$BEAGLE_STREAM_CLIENT_VIDEO_DECODER}"
  BEAGLE_STREAM_CLIENT_AUDIO_CONFIG="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_AUDIO_CONFIG:-$BEAGLE_STREAM_CLIENT_AUDIO_CONFIG}"
  BEAGLE_STREAM_CLIENT_ABSOLUTE_MOUSE="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_ABSOLUTE_MOUSE:-$BEAGLE_STREAM_CLIENT_ABSOLUTE_MOUSE}"
  BEAGLE_STREAM_CLIENT_QUIT_AFTER="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_QUIT_AFTER:-$BEAGLE_STREAM_CLIENT_QUIT_AFTER}"
  BEAGLE_STREAM_SERVER_API_URL="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_API_URL:-$BEAGLE_STREAM_SERVER_API_URL}"
  BEAGLE_STREAM_SERVER_USERNAME="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_USERNAME:-$BEAGLE_STREAM_SERVER_USERNAME}"
  BEAGLE_STREAM_SERVER_PASSWORD="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_PASSWORD:-$BEAGLE_STREAM_SERVER_PASSWORD}"
  BEAGLE_STREAM_SERVER_PINNED_PUBKEY="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_PINNED_PUBKEY:-$BEAGLE_STREAM_SERVER_PINNED_PUBKEY}"
  BEAGLE_STREAM_SERVER_NAME="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_NAME:-$BEAGLE_STREAM_SERVER_NAME}"
  BEAGLE_STREAM_SERVER_STREAM_PORT="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_STREAM_PORT:-$BEAGLE_STREAM_SERVER_STREAM_PORT}"
  BEAGLE_STREAM_SERVER_UNIQUEID="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_UNIQUEID:-$BEAGLE_STREAM_SERVER_UNIQUEID}"
  BEAGLE_STREAM_SERVER_CERT_B64="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_CERT_B64:-$BEAGLE_STREAM_SERVER_CERT_B64}"
  BEAGLE_HOST="${BEAGLE_ENDPOINT_BEAGLE_HOST:-$BEAGLE_HOST}"
  BEAGLE_PORT="${BEAGLE_ENDPOINT_BEAGLE_PORT:-$BEAGLE_PORT}"
  BEAGLE_NODE="${BEAGLE_ENDPOINT_BEAGLE_NODE:-$BEAGLE_NODE}"
  BEAGLE_VMID="${BEAGLE_ENDPOINT_BEAGLE_VMID:-$BEAGLE_VMID}"
  BEAGLE_REALM="${BEAGLE_ENDPOINT_BEAGLE_REALM:-$BEAGLE_REALM}"
  BEAGLE_VERIFY_TLS="${BEAGLE_ENDPOINT_BEAGLE_VERIFY_TLS:-$BEAGLE_VERIFY_TLS}"
  BEAGLE_MANAGER_TOKEN="${BEAGLE_ENDPOINT_BEAGLE_MANAGER_TOKEN:-$BEAGLE_MANAGER_TOKEN}"
  BEAGLE_EGRESS_MODE="${BEAGLE_ENDPOINT_EGRESS_MODE:-$BEAGLE_EGRESS_MODE}"
  BEAGLE_EGRESS_TYPE="${BEAGLE_ENDPOINT_EGRESS_TYPE:-$BEAGLE_EGRESS_TYPE}"
  BEAGLE_EGRESS_INTERFACE="${BEAGLE_ENDPOINT_EGRESS_INTERFACE:-$BEAGLE_EGRESS_INTERFACE}"
  BEAGLE_EGRESS_DOMAINS="${BEAGLE_ENDPOINT_EGRESS_DOMAINS:-$BEAGLE_EGRESS_DOMAINS}"
  BEAGLE_EGRESS_RESOLVERS="${BEAGLE_ENDPOINT_EGRESS_RESOLVERS:-$BEAGLE_EGRESS_RESOLVERS}"
  BEAGLE_EGRESS_ALLOWED_IPS="${BEAGLE_ENDPOINT_EGRESS_ALLOWED_IPS:-$BEAGLE_EGRESS_ALLOWED_IPS}"
  BEAGLE_EGRESS_WG_PRIVATE_KEY="${BEAGLE_ENDPOINT_EGRESS_WG_PRIVATE_KEY:-$BEAGLE_EGRESS_WG_PRIVATE_KEY}"
  BEAGLE_EGRESS_WG_ADDRESS="${BEAGLE_ENDPOINT_EGRESS_WG_ADDRESS:-$BEAGLE_EGRESS_WG_ADDRESS}"
  BEAGLE_EGRESS_WG_DNS="${BEAGLE_ENDPOINT_EGRESS_WG_DNS:-$BEAGLE_EGRESS_WG_DNS}"
  BEAGLE_EGRESS_WG_PUBLIC_KEY="${BEAGLE_ENDPOINT_EGRESS_WG_PUBLIC_KEY:-$BEAGLE_EGRESS_WG_PUBLIC_KEY}"
  BEAGLE_EGRESS_WG_ENDPOINT="${BEAGLE_ENDPOINT_EGRESS_WG_ENDPOINT:-$BEAGLE_EGRESS_WG_ENDPOINT}"
  BEAGLE_EGRESS_WG_PRESHARED_KEY="${BEAGLE_ENDPOINT_EGRESS_WG_PRESHARED_KEY:-$BEAGLE_EGRESS_WG_PRESHARED_KEY}"
  BEAGLE_EGRESS_WG_PERSISTENT_KEEPALIVE="${BEAGLE_ENDPOINT_EGRESS_WG_PERSISTENT_KEEPALIVE:-$BEAGLE_EGRESS_WG_PERSISTENT_KEEPALIVE}"
  IDENTITY_HOSTNAME="${BEAGLE_ENDPOINT_IDENTITY_HOSTNAME:-$IDENTITY_HOSTNAME}"
  IDENTITY_TIMEZONE="${BEAGLE_ENDPOINT_IDENTITY_TIMEZONE:-$IDENTITY_TIMEZONE}"
  IDENTITY_LOCALE="${BEAGLE_ENDPOINT_IDENTITY_LOCALE:-$IDENTITY_LOCALE}"
  IDENTITY_KEYMAP="${BEAGLE_ENDPOINT_IDENTITY_KEYMAP:-$IDENTITY_KEYMAP}"
  IDENTITY_CHROME_PROFILE="${BEAGLE_ENDPOINT_IDENTITY_CHROME_PROFILE:-$IDENTITY_CHROME_PROFILE}"
  NETWORK_MODE="${BEAGLE_ENDPOINT_NETWORK_MODE:-$NETWORK_MODE}"
  NETWORK_INTERFACE="${BEAGLE_ENDPOINT_NETWORK_INTERFACE:-$NETWORK_INTERFACE}"
  NETWORK_STATIC_ADDRESS="${BEAGLE_ENDPOINT_NETWORK_STATIC_ADDRESS:-$NETWORK_STATIC_ADDRESS}"
  NETWORK_STATIC_PREFIX="${BEAGLE_ENDPOINT_NETWORK_STATIC_PREFIX:-$NETWORK_STATIC_PREFIX}"
  NETWORK_GATEWAY="${BEAGLE_ENDPOINT_NETWORK_GATEWAY:-$NETWORK_GATEWAY}"
  NETWORK_DNS_SERVERS="${BEAGLE_ENDPOINT_NETWORK_DNS_SERVERS:-$NETWORK_DNS_SERVERS}"
fi

if [[ -z "$AUTOSTART" ]]; then
  if [[ -n "$BEAGLE_STREAM_CLIENT_HOST" ]]; then
    AUTOSTART="1"
  else
    AUTOSTART="0"
  fi
fi

if [[ -z "$BEAGLE_STREAM_SERVER_API_URL" && -n "$BEAGLE_STREAM_CLIENT_HOST" ]]; then
  if [[ -n "$BEAGLE_STREAM_CLIENT_PORT" ]]; then
    BEAGLE_STREAM_SERVER_API_URL="https://${BEAGLE_STREAM_CLIENT_HOST}:$((BEAGLE_STREAM_CLIENT_PORT + 1))"
  else
    BEAGLE_STREAM_SERVER_API_URL="https://${BEAGLE_STREAM_CLIENT_HOST}:47990"
  fi
fi

if [[ ! -x "$WRITE_CONFIG" ]]; then
  echo "Missing runtime config writer: $WRITE_CONFIG" >&2
  exit 1
fi

MODE="BEAGLE_STREAM_CLIENT" \
RUNTIME_USER="$RUNTIME_USER" \
AUTOSTART="$AUTOSTART" \
PROFILE_NAME="$PROFILE_NAME" \
HOSTNAME_VALUE="$(hostname)" \
BEAGLE_STREAM_CLIENT_HOST="$BEAGLE_STREAM_CLIENT_HOST" \
BEAGLE_STREAM_CLIENT_LOCAL_HOST="$BEAGLE_STREAM_CLIENT_LOCAL_HOST" \
BEAGLE_STREAM_CLIENT_PORT="$BEAGLE_STREAM_CLIENT_PORT" \
BEAGLE_STREAM_CLIENT_APP="$BEAGLE_STREAM_CLIENT_APP" \
BEAGLE_STREAM_CLIENT_BIN="beagle-stream-client" \
BEAGLE_STREAM_CLIENT_RESOLUTION="$BEAGLE_STREAM_CLIENT_RESOLUTION" \
BEAGLE_STREAM_CLIENT_FPS="$BEAGLE_STREAM_CLIENT_FPS" \
BEAGLE_STREAM_CLIENT_BITRATE="$BEAGLE_STREAM_CLIENT_BITRATE" \
BEAGLE_STREAM_CLIENT_VIDEO_CODEC="$BEAGLE_STREAM_CLIENT_VIDEO_CODEC" \
BEAGLE_STREAM_CLIENT_VIDEO_DECODER="$BEAGLE_STREAM_CLIENT_VIDEO_DECODER" \
BEAGLE_STREAM_CLIENT_AUDIO_CONFIG="$BEAGLE_STREAM_CLIENT_AUDIO_CONFIG" \
BEAGLE_STREAM_CLIENT_ABSOLUTE_MOUSE="$BEAGLE_STREAM_CLIENT_ABSOLUTE_MOUSE" \
BEAGLE_STREAM_CLIENT_QUIT_AFTER="$BEAGLE_STREAM_CLIENT_QUIT_AFTER" \
BEAGLE_STREAM_SERVER_API_URL="$BEAGLE_STREAM_SERVER_API_URL" \
BEAGLE_HOST="$BEAGLE_HOST" \
BEAGLE_PORT="$BEAGLE_PORT" \
BEAGLE_NODE="$BEAGLE_NODE" \
BEAGLE_VMID="$BEAGLE_VMID" \
BEAGLE_REALM="$BEAGLE_REALM" \
BEAGLE_VERIFY_TLS="$BEAGLE_VERIFY_TLS" \
BEAGLE_EGRESS_MODE="$BEAGLE_EGRESS_MODE" \
BEAGLE_EGRESS_TYPE="$BEAGLE_EGRESS_TYPE" \
BEAGLE_EGRESS_INTERFACE="$BEAGLE_EGRESS_INTERFACE" \
BEAGLE_EGRESS_DOMAINS="$BEAGLE_EGRESS_DOMAINS" \
BEAGLE_EGRESS_RESOLVERS="$BEAGLE_EGRESS_RESOLVERS" \
BEAGLE_EGRESS_ALLOWED_IPS="$BEAGLE_EGRESS_ALLOWED_IPS" \
BEAGLE_EGRESS_WG_PRIVATE_KEY="$BEAGLE_EGRESS_WG_PRIVATE_KEY" \
BEAGLE_EGRESS_WG_ADDRESS="$BEAGLE_EGRESS_WG_ADDRESS" \
BEAGLE_EGRESS_WG_DNS="$BEAGLE_EGRESS_WG_DNS" \
BEAGLE_EGRESS_WG_PUBLIC_KEY="$BEAGLE_EGRESS_WG_PUBLIC_KEY" \
BEAGLE_EGRESS_WG_ENDPOINT="$BEAGLE_EGRESS_WG_ENDPOINT" \
BEAGLE_EGRESS_WG_PRESHARED_KEY="$BEAGLE_EGRESS_WG_PRESHARED_KEY" \
BEAGLE_EGRESS_WG_PERSISTENT_KEEPALIVE="$BEAGLE_EGRESS_WG_PERSISTENT_KEEPALIVE" \
IDENTITY_HOSTNAME="$IDENTITY_HOSTNAME" \
IDENTITY_TIMEZONE="$IDENTITY_TIMEZONE" \
IDENTITY_LOCALE="$IDENTITY_LOCALE" \
IDENTITY_KEYMAP="$IDENTITY_KEYMAP" \
IDENTITY_CHROME_PROFILE="$IDENTITY_CHROME_PROFILE" \
NETWORK_MODE="$NETWORK_MODE" \
NETWORK_INTERFACE="$NETWORK_INTERFACE" \
NETWORK_STATIC_ADDRESS="$NETWORK_STATIC_ADDRESS" \
NETWORK_STATIC_PREFIX="$NETWORK_STATIC_PREFIX" \
NETWORK_GATEWAY="$NETWORK_GATEWAY" \
NETWORK_DNS_SERVERS="$NETWORK_DNS_SERVERS" \
BEAGLE_MANAGER_TOKEN="$BEAGLE_MANAGER_TOKEN" \
BEAGLE_STREAM_SERVER_PINNED_PUBKEY="$BEAGLE_STREAM_SERVER_PINNED_PUBKEY" \
BEAGLE_STREAM_SERVER_USERNAME="$BEAGLE_STREAM_SERVER_USERNAME" \
BEAGLE_STREAM_SERVER_PASSWORD="$BEAGLE_STREAM_SERVER_PASSWORD" \
BEAGLE_STREAM_SERVER_NAME="$BEAGLE_STREAM_SERVER_NAME" \
BEAGLE_STREAM_SERVER_STREAM_PORT="$BEAGLE_STREAM_SERVER_STREAM_PORT" \
BEAGLE_STREAM_SERVER_UNIQUEID="$BEAGLE_STREAM_SERVER_UNIQUEID" \
BEAGLE_STREAM_SERVER_CERT_B64="$BEAGLE_STREAM_SERVER_CERT_B64" \
"$WRITE_CONFIG" /etc/pve-thin-client
