#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/beagle-os"
STATUS_FILE="$STATE_DIR/egress.status"
ENDPOINT_FILE="/etc/beagle-os/endpoint.env"
COMMON_SH="/usr/local/lib/pve-thin-client/common.sh"
WG_DIR="/etc/wireguard"
TABLE_ID="51820"

install -d -m 0755 "$STATE_DIR" "$WG_DIR"

if [[ -r "$ENDPOINT_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENDPOINT_FILE"
fi

if [[ -r "$COMMON_SH" ]]; then
  # shellcheck disable=SC1090
  source "$COMMON_SH"
  load_runtime_config >/dev/null 2>&1 || true
fi

mode="${BEAGLE_ENDPOINT_EGRESS_MODE:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_MODE:-direct}}"
egress_type="${BEAGLE_ENDPOINT_EGRESS_TYPE:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_TYPE:-}}"
interface_name="${BEAGLE_ENDPOINT_EGRESS_INTERFACE:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_INTERFACE:-beagle-egress}}"
domain_list="${BEAGLE_ENDPOINT_EGRESS_DOMAINS:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_DOMAINS:-}}"
resolver_list="${BEAGLE_ENDPOINT_EGRESS_RESOLVERS:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_RESOLVERS:-1.1.1.1 8.8.8.8}}"
allowed_ip_list="${BEAGLE_ENDPOINT_EGRESS_ALLOWED_IPS:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_ALLOWED_IPS:-}}"
wg_private_key="${BEAGLE_ENDPOINT_EGRESS_WG_PRIVATE_KEY:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_PRIVATE_KEY:-}}"
wg_address="${BEAGLE_ENDPOINT_EGRESS_WG_ADDRESS:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_ADDRESS:-}}"
wg_dns="${BEAGLE_ENDPOINT_EGRESS_WG_DNS:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_DNS:-}}"
wg_public_key="${BEAGLE_ENDPOINT_EGRESS_WG_PUBLIC_KEY:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_PUBLIC_KEY:-}}"
wg_endpoint="${BEAGLE_ENDPOINT_EGRESS_WG_ENDPOINT:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_ENDPOINT:-}}"
wg_preshared_key="${BEAGLE_ENDPOINT_EGRESS_WG_PRESHARED_KEY:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_PRESHARED_KEY:-}}"
wg_keepalive="${BEAGLE_ENDPOINT_EGRESS_WG_PERSISTENT_KEEPALIVE:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_WG_PERSISTENT_KEEPALIVE:-25}}"

read_previous_value() {
  local key="$1"
  [[ -r "$STATUS_FILE" ]] || return 1
  awk -F= -v wanted="$key" '$1 == wanted {print substr($0, index($0, "=") + 1); exit}' "$STATUS_FILE"
}

delete_previous_split_routes() {
  local previous route
  previous="$(read_previous_value route_destinations || true)"
  [[ -n "$previous" ]] || return 0
  for route in $previous; do
    ip route del "$route" dev "$interface_name" >/dev/null 2>&1 || true
  done
  ip rule del fwmark "$TABLE_ID" table "$TABLE_ID" priority "$TABLE_ID" >/dev/null 2>&1 || true
  ip route flush table "$TABLE_ID" >/dev/null 2>&1 || true
}

write_status() {
  local state="$1"
  local route_count="$2"
  local destinations="$3"
  local public_ip="$4"
  {
    printf 'timestamp=%s\n' "$(date -Iseconds)"
    printf 'mode=%q\n' "$mode"
    printf 'type=%q\n' "$egress_type"
    printf 'interface=%q\n' "$interface_name"
    printf 'state=%q\n' "$state"
    printf 'domains=%q\n' "$domain_list"
    printf 'resolvers=%q\n' "$resolver_list"
    printf 'allowed_ips=%q\n' "$allowed_ip_list"
    printf 'route_count=%q\n' "$route_count"
    printf 'route_destinations=%q\n' "$destinations"
    printf 'public_ip=%q\n' "$public_ip"
  } >"$STATUS_FILE"
  chmod 0644 "$STATUS_FILE"
}

if [[ "$mode" == "direct" || -z "$egress_type" ]]; then
  delete_previous_split_routes
  wg-quick down "$interface_name" >/dev/null 2>&1 || true
  write_status "direct" "0" "" ""
  exit 0
fi

if [[ "$egress_type" != "wireguard" ]]; then
  write_status "unsupported" "0" "" ""
  exit 0
fi

if ! command -v wg-quick >/dev/null 2>&1; then
  write_status "missing-wg-quick" "0" "" ""
  exit 0
fi

if [[ -z "$wg_private_key" || -z "$wg_address" || -z "$wg_public_key" || -z "$wg_endpoint" ]]; then
  write_status "missing-wireguard-config" "0" "" ""
  exit 0
fi

config_path="$WG_DIR/${interface_name}.conf"
umask 077
{
  printf '[Interface]\n'
  printf 'Address = %s\n' "$wg_address"
  printf 'PrivateKey = %s\n' "$wg_private_key"
  [[ -n "$wg_dns" ]] && printf 'DNS = %s\n' "$wg_dns"
  if [[ "$mode" == "split" ]]; then
    printf 'Table = off\n'
  fi
  printf '\n[Peer]\n'
  printf 'PublicKey = %s\n' "$wg_public_key"
  [[ -n "$wg_preshared_key" ]] && printf 'PresharedKey = %s\n' "$wg_preshared_key"
  printf 'AllowedIPs = 0.0.0.0/0\n'
  printf 'Endpoint = %s\n' "$wg_endpoint"
  printf 'PersistentKeepalive = %s\n' "$wg_keepalive"
} >"$config_path"
chmod 0600 "$config_path"

delete_previous_split_routes
wg-quick down "$interface_name" >/dev/null 2>&1 || true
wg-quick up "$interface_name" >/dev/null 2>&1

route_destinations=""
route_count=0
if [[ "$mode" == "split" ]]; then
  ip rule add fwmark "$TABLE_ID" table "$TABLE_ID" priority "$TABLE_ID" >/dev/null 2>&1 || true
  ip route add default dev "$interface_name" table "$TABLE_ID" >/dev/null 2>&1 || true
  for cidr in $allowed_ip_list; do
    ip route replace "$cidr" dev "$interface_name" >/dev/null 2>&1 || true
    route_destinations="$route_destinations $cidr"
    route_count=$((route_count + 1))
  done
  for domain in $domain_list; do
    while IFS= read -r ipv4; do
      [[ -n "$ipv4" ]] || continue
      ip route replace "$ipv4/32" dev "$interface_name" >/dev/null 2>&1 || true
      route_destinations="$route_destinations $ipv4/32"
      route_count=$((route_count + 1))
    done < <(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1}' | sort -u)
  done
fi

public_ip="$(
  curl --interface "$interface_name" -4fsS --connect-timeout 4 --max-time 8 https://api.ipify.org 2>/dev/null || true
)"
write_status "active" "$route_count" "${route_destinations# }" "$public_ip"
