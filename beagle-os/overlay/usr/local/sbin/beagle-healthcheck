#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/beagle-os"
LOG_DIR="/var/log/beagle-os"
HEALTH_FILE="$STATE_DIR/health.status"
ENDPOINT_FILE="/etc/beagle-os/endpoint.env"
COMMON_SH="/usr/local/lib/pve-thin-client/runtime/common.sh"

install -d -m 0755 "$STATE_DIR" "$LOG_DIR"

if [[ -r "$ENDPOINT_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENDPOINT_FILE"
fi

if [[ -r "$COMMON_SH" ]]; then
  # shellcheck disable=SC1090
  source "$COMMON_SH"
  load_runtime_config >/dev/null 2>&1 || true
fi

beagle_stream_client_host="${BEAGLE_ENDPOINT_BEAGLE_STREAM_CLIENT_HOST:-${PVE_THIN_CLIENT_BEAGLE_STREAM_CLIENT_HOST:-}}"
beagle_stream_server_api_url="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_API_URL:-${PVE_THIN_CLIENT_BEAGLE_STREAM_SERVER_API_URL:-}}"
beagle_stream_server_username="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_USERNAME:-${PVE_THIN_CLIENT_BEAGLE_STREAM_SERVER_USERNAME:-}}"
beagle_stream_server_password="${BEAGLE_ENDPOINT_BEAGLE_STREAM_SERVER_PASSWORD:-${PVE_THIN_CLIENT_BEAGLE_STREAM_SERVER_PASSWORD:-}}"
network_mode="${BEAGLE_ENDPOINT_NETWORK_MODE:-${PVE_THIN_CLIENT_NETWORK_MODE:-dhcp}}"
autostart="${BEAGLE_ENDPOINT_AUTOSTART:-${PVE_THIN_CLIENT_AUTOSTART:-0}}"
manager_url="${BEAGLE_ENDPOINT_MANAGER_URL:-${PVE_THIN_CLIENT_BEAGLE_MANAGER_URL:-}}"
egress_mode="${BEAGLE_ENDPOINT_EGRESS_MODE:-${PVE_THIN_CLIENT_BEAGLE_EGRESS_MODE:-direct}}"
identity_timezone="${BEAGLE_ENDPOINT_IDENTITY_TIMEZONE:-${PVE_THIN_CLIENT_IDENTITY_TIMEZONE:-}}"
hostname_value="$(hostname)"
ip_summary="$(ip -br addr 2>/dev/null | tr '\n' ';' | sed 's/;$/\n/' || true)"
default_route="$(ip route show default 2>/dev/null | head -n 1 || true)"
network_state="$(systemctl is-active NetworkManager.service 2>/dev/null || true)"
ssh_state="$(systemctl is-active ssh.service 2>/dev/null || true)"
autologin_state="$(systemctl is-active beagle-autologin.service 2>/dev/null || true)"
endpoint_report_timer_state="$(systemctl is-active beagle-endpoint-report.timer 2>/dev/null || true)"
endpoint_dispatch_timer_state="$(systemctl is-active beagle-endpoint-dispatch.timer 2>/dev/null || true)"
update_scan_timer_state="$(systemctl is-active beagle-update-scan.timer 2>/dev/null || true)"
prepare_state="$(systemctl is-active beagle-thin-client-prepare.service 2>/dev/null || systemctl is-active pve-thin-client-prepare.service 2>/dev/null || true)"
guest_agent_state="$(systemctl is-active qemu-guest-agent.service 2>/dev/null || true)"
beagle_stream_client_binary="0"
beagle_stream_binary="0"
beagle_stream_hostless="0"
beagle_stream_client_target_reachable="0"
beagle_stream_server_api_reachable="0"
external_ip="$(curl -4fsS --connect-timeout 3 --max-time 6 https://api.ipify.org 2>/dev/null || true)"
virtualization_type="$(systemd-detect-virt 2>/dev/null || true)"
monitor_summary="$(xrandr --listmonitors 2>/dev/null | tr '\n' ';' | sed 's/;$/\n/' || true)"
egress_state="$(awk -F= '$1 == "state" {print substr($0, index($0, "=") + 1); exit}' /var/lib/beagle-os/egress.status 2>/dev/null || true)"
egress_public_ip="$(awk -F= '$1 == "public_ip" {print substr($0, index($0, "=") + 1); exit}' /var/lib/beagle-os/egress.status 2>/dev/null || true)"
identity_locale="$(awk -F= '$1 == "locale" {print substr($0, index($0, "=") + 1); exit}' /var/lib/beagle-os/identity.status 2>/dev/null || true)"
identity_keymap="$(awk -F= '$1 == "keymap" {print substr($0, index($0, "=") + 1); exit}' /var/lib/beagle-os/identity.status 2>/dev/null || true)"
client_mode="${PVE_THIN_CLIENT_CLIENT_MODE:-$(cmdline_var pve_thin_client.client_mode 2>/dev/null || true)}"
kiosk_state="$(systemctl is-active beagle-kiosk.service 2>/dev/null || true)"

if command -v beagle-stream-client >/dev/null 2>&1; then
  beagle_stream_client_binary="1"
fi
if command -v beagle-stream >/dev/null 2>&1; then
  beagle_stream_binary="1"
fi
if [[ -z "$beagle_stream_client_host" && -r /etc/beagle/enrollment.conf ]] \
  && grep -q '^control_plane=' /etc/beagle/enrollment.conf \
  && grep -q '^enrollment_token=' /etc/beagle/enrollment.conf \
  && grep -q '^device_id=' /etc/beagle/enrollment.conf \
  && grep -q '^pool_id=' /etc/beagle/enrollment.conf; then
  beagle_stream_hostless="1"
fi

if [[ -n "$beagle_stream_client_host" ]]; then
  if ping -c 1 -W 2 "$beagle_stream_client_host" >/dev/null 2>&1; then
    beagle_stream_client_target_reachable="1"
  fi
fi

if [[ -n "$beagle_stream_server_api_url" ]]; then
  curl_args=(-fsS --connect-timeout 2 --max-time 4 -o /dev/null)
  mapfile -t tls_args < <(beagle_curl_tls_args "$beagle_stream_server_api_url" "${PVE_THIN_CLIENT_BEAGLE_STREAM_SERVER_PINNED_PUBKEY:-}" "${PVE_THIN_CLIENT_BEAGLE_STREAM_SERVER_CA_CERT:-}")
  curl_args+=("${tls_args[@]}")
  if [[ -n "$beagle_stream_server_username" && -n "$beagle_stream_server_password" ]]; then
    curl_args+=(--user "${beagle_stream_server_username}:${beagle_stream_server_password}")
  fi
  if curl "${curl_args[@]}" "${beagle_stream_server_api_url%/}/api/apps"; then
    beagle_stream_server_api_reachable="1"
  fi
fi

cat >"$HEALTH_FILE" <<EOF
timestamp=$(date -Iseconds)
hostname=$hostname_value
network_mode=$network_mode
autostart=$autostart
client_mode=${client_mode:-UNSET}
beagle_stream_client_host=${beagle_stream_client_host:-UNSET}
beagle_stream_server_api_url=${beagle_stream_server_api_url:-UNSET}
beagle_stream_client_binary=$beagle_stream_client_binary
beagle_stream_binary=$beagle_stream_binary
beagle_stream_hostless=$beagle_stream_hostless
beagle_stream_client_target_reachable=$beagle_stream_client_target_reachable
beagle_stream_server_api_reachable=$beagle_stream_server_api_reachable
networkmanager_state=${network_state:-unknown}
ssh_state=${ssh_state:-unknown}
autologin_state=${autologin_state:-unknown}
endpoint_report_timer_state=${endpoint_report_timer_state:-unknown}
endpoint_dispatch_timer_state=${endpoint_dispatch_timer_state:-unknown}
update_scan_timer_state=${update_scan_timer_state:-unknown}
kiosk_state=${kiosk_state:-unknown}
prepare_state=${prepare_state:-unknown}
guest_agent_state=${guest_agent_state:-unknown}
manager_url=${manager_url:-UNSET}
egress_mode=${egress_mode:-direct}
egress_state=${egress_state:-unknown}
egress_public_ip=${egress_public_ip:-UNSET}
external_ip=${external_ip:-UNSET}
virtualization_type=${virtualization_type:-none}
identity_timezone=${identity_timezone:-UNSET}
identity_locale=${identity_locale:-UNSET}
identity_keymap=${identity_keymap:-UNSET}
default_route=${default_route:-UNSET}
ip_summary=${ip_summary:-UNSET}
monitor_summary=${monitor_summary:-UNSET}
EOF

cp "$HEALTH_FILE" "$LOG_DIR/health.status"

health_failure_reasons=()
if [[ "$beagle_stream_client_binary" != "1" && "$beagle_stream_binary" != "1" ]]; then
  health_failure_reasons+=("beagle-stream-client binary missing")
fi
if [[ "$beagle_stream_hostless" == "1" && "$beagle_stream_binary" != "1" ]]; then
  health_failure_reasons+=("beagle-stream binary missing")
fi
if [[ -n "$beagle_stream_client_host" && "$beagle_stream_client_target_reachable" != "1" ]]; then
  health_failure_reasons+=("beagle-stream-client target unreachable")
fi
if [[ -n "$beagle_stream_server_api_url" && "$beagle_stream_server_api_reachable" != "1" ]]; then
  health_failure_reasons+=("beagle-stream-server api unreachable")
fi
if [[ "${egress_mode:-direct}" != "direct" && "${egress_state:-unknown}" != "ready" && "${egress_state:-unknown}" != "ok" && "${egress_state:-unknown}" != "active" ]]; then
  health_failure_reasons+=("secure egress not ready")
fi

if (( ${#health_failure_reasons[@]} > 0 )) && [[ -x /usr/local/sbin/beagle-update-client ]]; then
  reason="$(IFS='; '; printf '%s' "${health_failure_reasons[*]}")"
  /usr/local/sbin/beagle-update-client mark-health-failed --reason "$reason" >/dev/null 2>&1 || true
fi
