#!/usr/bin/env bash
set -euo pipefail

INSTALL_ROOT="${BEAGLE_KIOSK_ROOT:-/opt/beagle-kiosk}"
LAUNCHER="${INSTALL_ROOT}/launch.sh"

export BEAGLE_KIOSK_ROOT="$INSTALL_ROOT"

if [[ ! -x "$LAUNCHER" ]]; then
  echo "beagle-kiosk is not installed under ${INSTALL_ROOT}" >&2
  exit 1
fi

exec "$LAUNCHER"
