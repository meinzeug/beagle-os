#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/beagle-os"
STATUS_FILE="$STATE_DIR/identity.status"
ENDPOINT_FILE="/etc/beagle-os/endpoint.env"
COMMON_SH="/usr/local/lib/pve-thin-client/common.sh"

install -d -m 0755 "$STATE_DIR"

if [[ -r "$ENDPOINT_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENDPOINT_FILE"
fi

if [[ -r "$COMMON_SH" ]]; then
  # shellcheck disable=SC1090
  source "$COMMON_SH"
  load_runtime_config >/dev/null 2>&1 || true
fi

runtime_user="${BEAGLE_OS_RUNTIME_USER:-${PVE_THIN_CLIENT_RUNTIME_USER:-thinclient}}"
desired_hostname="${BEAGLE_ENDPOINT_IDENTITY_HOSTNAME:-${PVE_THIN_CLIENT_IDENTITY_HOSTNAME:-}}"
desired_timezone="${BEAGLE_ENDPOINT_IDENTITY_TIMEZONE:-${PVE_THIN_CLIENT_IDENTITY_TIMEZONE:-}}"
desired_locale="${BEAGLE_ENDPOINT_IDENTITY_LOCALE:-${PVE_THIN_CLIENT_IDENTITY_LOCALE:-}}"
desired_keymap="${BEAGLE_ENDPOINT_IDENTITY_KEYMAP:-${PVE_THIN_CLIENT_IDENTITY_KEYMAP:-}}"
chrome_profile="${BEAGLE_ENDPOINT_IDENTITY_CHROME_PROFILE:-${PVE_THIN_CLIENT_IDENTITY_CHROME_PROFILE:-default}}"

apply_hostname() {
  local value="$1" hosts_file temp_file
  [[ -n "$value" ]] || return 0
  printf '%s\n' "$value" >/etc/hostname
  hostname "$value" >/dev/null 2>&1 || true
  hosts_file="/etc/hosts"
  [[ -f "$hosts_file" ]] || return 0
  temp_file="$(mktemp)"
  awk '$1 == "127.0.1.1" {next} {print}' "$hosts_file" >"$temp_file"
  {
    cat "$temp_file"
    printf '127.0.1.1 %s\n' "$value"
  } >"$hosts_file"
  rm -f "$temp_file"
}

apply_timezone() {
  local value="$1" tz_file
  [[ -n "$value" ]] || return 0
  tz_file="/usr/share/zoneinfo/$value"
  [[ -e "$tz_file" ]] || return 0
  ln -sf "$tz_file" /etc/localtime
  printf '%s\n' "$value" >/etc/timezone
}

apply_locale() {
  local value="$1"
  [[ -n "$value" ]] || return 0
  if [[ -w /etc/locale.gen ]]; then
    if ! grep -Eq "^[# ]*${value}[[:space:]]+UTF-8" /etc/locale.gen; then
      printf '%s UTF-8\n' "$value" >>/etc/locale.gen
    else
      sed -i "s/^[# ]*\\(${value}[[:space:]]\\+UTF-8\\)/\\1/" /etc/locale.gen || true
    fi
  fi
  if command -v locale-gen >/dev/null 2>&1; then
    locale-gen "$value" >/dev/null 2>&1 || true
  fi
  if command -v update-locale >/dev/null 2>&1; then
    update-locale "LANG=$value" >/dev/null 2>&1 || true
  fi
}

apply_keymap() {
  local value="$1"
  [[ -n "$value" ]] || return 0
  if command -v localectl >/dev/null 2>&1; then
    localectl set-keymap "$value" >/dev/null 2>&1 || true
  fi
}

prepare_chrome_profile() {
  local user_name="$1"
  local profile_name="$2"
  local home_dir profile_dir
  id "$user_name" >/dev/null 2>&1 || return 0
  home_dir="$(getent passwd "$user_name" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || return 0
  profile_dir="$home_dir/.config/beagle-browser/$profile_name"
  install -d -m 0700 -o "$user_name" -g "$user_name" "$profile_dir"
  printf '%s\n' "$profile_dir" >"$STATE_DIR/chrome-profile.path"
}

apply_hostname "$desired_hostname"
apply_timezone "$desired_timezone"
apply_locale "$desired_locale"
apply_keymap "$desired_keymap"
prepare_chrome_profile "$runtime_user" "$chrome_profile"

{
  printf 'timestamp=%s\n' "$(date -Iseconds)"
  printf 'runtime_user=%q\n' "$runtime_user"
  printf 'hostname=%q\n' "${desired_hostname:-$(hostname)}"
  printf 'timezone=%q\n' "${desired_timezone:-$(cat /etc/timezone 2>/dev/null || true)}"
  printf 'locale=%q\n' "${desired_locale:-${LANG:-}}"
  printf 'keymap=%q\n' "${desired_keymap:-}"
  printf 'chrome_profile=%q\n' "$chrome_profile"
  printf 'machine_id=%q\n' "$(cat /etc/machine-id 2>/dev/null || true)"
} >"$STATUS_FILE"

chmod 0644 "$STATUS_FILE"
