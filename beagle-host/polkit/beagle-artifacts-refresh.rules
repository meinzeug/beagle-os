// Managed by Beagle OS. Allows the beagle-manager service user to start the
// artifact refresh unit without interactive authentication.
polkit.addRule(function(action, subject) {
  if (action.id !== "org.freedesktop.systemd1.manage-units") {
    return polkit.Result.NOT_HANDLED;
  }
  if (subject.user !== "beagle-manager") {
    return polkit.Result.NOT_HANDLED;
  }
  var unit = action.lookup("unit");
  var verb = action.lookup("verb");
  if (unit === "beagle-artifacts-refresh.service" && verb === "start") {
    return polkit.Result.YES;
  }
  return polkit.Result.NOT_HANDLED;
});
