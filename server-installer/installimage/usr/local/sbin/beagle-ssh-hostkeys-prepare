#!/usr/bin/env bash
set -euo pipefail

remove_empty_host_keys() {
  local key_path=""
  for key_path in /etc/ssh/ssh_host_*_key /etc/ssh/ssh_host_*_key.pub; do
    [[ -e "$key_path" ]] || continue
    [[ -s "$key_path" ]] && continue
    rm -f "$key_path"
  done
}

have_valid_host_keys() {
  local key_path=""
  for key_path in /etc/ssh/ssh_host_*_key; do
    [[ -s "$key_path" ]] || continue
    return 0
  done
  return 1
}

remove_empty_host_keys
if ! have_valid_host_keys; then
  ssh-keygen -A >/dev/null 2>&1 || true
fi
