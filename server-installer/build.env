# Beagle Server Installer build defaults
# Source this file in scripts/build-server-installer.sh to keep build prerequisites
# reproducible on fresh Debian hosts.

# Disk-space guardrails in GiB.
BEAGLE_SERVER_INSTALLER_MIN_BUILD_FREE_GIB=14
BEAGLE_SERVER_INSTALLER_MIN_DIST_FREE_GIB=4

# Debian packages required to run a full live-build from this repository.
BEAGLE_SERVER_INSTALLER_BUILD_DEPENDENCIES="live-build debootstrap squashfs-tools xorriso grub2-common grub-pc-bin grub-efi-amd64-bin dosfstools mtools syslinux-utils rsync curl ca-certificates"
