#!/bin/sh
set -e

# Create stable symlinks so grub.cfg can reference /live/vmlinuz and
# /live/initrd regardless of the kernel version string.

cd binary/live

for f in vmlinuz-*; do
    [ -e "$f" ] || continue
    ln -sfn "$f" vmlinuz
    break
done

for f in initrd.img-*; do
    [ -e "$f" ] || continue
    ln -sfn "$f" initrd
    break
done
