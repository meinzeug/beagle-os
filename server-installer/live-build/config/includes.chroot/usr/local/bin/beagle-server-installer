#!/usr/bin/env bash
set -Eeuo pipefail

DONE_FILE="/run/beagle-server-installer.done"
STATE_DIR="/run/beagle-server-installer"
LOG_DIR="/var/log"
LOG_FILE="$LOG_DIR/beagle-server-installer.log"
TARGET_MOUNT="/mnt/beagle-server-target"
EFI_MOUNT="$TARGET_MOUNT/boot/efi"
TARGET_DISK=""
INSTALL_HOSTNAME=""
INSTALL_USERNAME=""
INSTALL_PASSWORD=""
INSTALL_DISK=""
PRIMARY_IFACE=""

DEBIAN_RELEASE="${BEAGLE_SERVER_DEBIAN_RELEASE:-bookworm}"
DEBIAN_MIRROR="${BEAGLE_SERVER_DEBIAN_MIRROR:-https://deb.debian.org/debian}"
DEBIAN_SECURITY_MIRROR="${BEAGLE_SERVER_DEBIAN_SECURITY_MIRROR:-https://security.debian.org/debian-security}"
BEAGLE_SERVER_INSTALL_MODE="${BEAGLE_SERVER_INSTALL_MODE:-}"
BEAGLE_SERVER_HOST_PROVIDER="${BEAGLE_SERVER_HOST_PROVIDER:-proxmox}"
PROXMOX_REPO_URL="${BEAGLE_SERVER_PROXMOX_REPO_URL:-http://download.proxmox.com/debian/pve}"
PROXMOX_REPO_SUITE="${BEAGLE_SERVER_PROXMOX_REPO_SUITE:-bookworm}"
PROXMOX_REPO_COMPONENT="${BEAGLE_SERVER_PROXMOX_REPO_COMPONENT:-pve-no-subscription}"
PROXMOX_KEY_URL="${BEAGLE_SERVER_PROXMOX_KEY_URL:-https://enterprise.proxmox.com/debian/proxmox-release-bookworm.gpg}"
BEAGLE_SOURCE_URL="${BEAGLE_SERVER_SOURCE_URL:-https://github.com/meinzeug/beagle-os/releases/download/v__BEAGLE_RELEASE_VERSION__/beagle-os-v__BEAGLE_RELEASE_VERSION__.tar.gz}"
BEAGLE_PUBLIC_UPDATE_BASE_URL="${BEAGLE_SERVER_PUBLIC_UPDATE_BASE_URL:-https://github.com/meinzeug/beagle-os/releases/download/v__BEAGLE_RELEASE_VERSION__}"
BEAGLE_INSTALL_DIR="${BEAGLE_SERVER_INSTALL_DIR:-/opt/beagle}"

cleanup() {
  umount "$TARGET_MOUNT/dev/pts" >/dev/null 2>&1 || true
  umount "$TARGET_MOUNT/dev" >/dev/null 2>&1 || true
  umount "$TARGET_MOUNT/proc" >/dev/null 2>&1 || true
  umount "$TARGET_MOUNT/sys" >/dev/null 2>&1 || true
  umount "$TARGET_MOUNT/run" >/dev/null 2>&1 || true
  umount "$EFI_MOUNT" >/dev/null 2>&1 || true
  umount "$TARGET_MOUNT" >/dev/null 2>&1 || true
}
trap cleanup EXIT

setup_logging() {
  mkdir -p "$STATE_DIR" "$LOG_DIR"
  touch "$LOG_FILE"
  chmod 0644 "$LOG_FILE" >/dev/null 2>&1 || true
}

log() {
  setup_logging
  printf '[%s] %s\n' "$(date -Is 2>/dev/null || date)" "$*" | tee -a "$LOG_FILE" >/dev/null
}

on_error() {
  local rc="$1"
  local line="$2"
  local cmd="$3"
  log "error: rc=$rc line=$line cmd=$cmd"
  printf '\nInstallation failed.\n\nSee %s for details.\n\nPress ENTER to open a shell.' "$LOG_FILE"
  read -r _
  exec /bin/bash -l
}
trap 'on_error $? "$LINENO" "$BASH_COMMAND"' ERR

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "This installer must run as root." >&2
    exit 1
  fi
}

run_logged() {
  log "run: $*"
  "$@" >>"$LOG_FILE" 2>&1
}

prompt_value() {
  local label="$1"
  local default_value="${2:-}"
  local value=""
  if [[ -n "$default_value" ]]; then
    printf '%s [%s]: ' "$label" "$default_value" >&2
  else
    printf '%s: ' "$label" >&2
  fi
  IFS= read -r value || true
  value="${value//$'\r'/}"
  if [[ -n "$value" ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$default_value"
  fi
}

prompt_secret() {
  local label="$1"
  local value=""
  read -r -s -p "$label: " value || true
  value="${value//$'\r'/}"
  printf '\n' >&2
  printf '%s\n' "$value"
}

prompt_password() {
  local first="" second=""
  while true; do
    first="$(prompt_secret 'Linux password')"
    [[ -n "$first" ]] || {
      echo "Password must not be empty." >&2
      continue
    }
    second="$(prompt_secret 'Confirm password')"
    [[ "$first" == "$second" ]] || {
      echo "Passwords do not match." >&2
      continue
    }
    printf '%s\n' "$first"
    return 0
  done
}

normalize_hostname() {
  printf '%s\n' "$1" | tr '[:upper:]' '[:lower:]'
}

install_mode_kind() {
  local mode provider
  mode="$(printf '%s' "${BEAGLE_SERVER_INSTALL_MODE:-}" | tr '[:upper:]' '[:lower:]')"
  case "$mode" in
    standalone|beagle|beagle-os|beagle_os)
      printf 'standalone\n'
      return 0
      ;;
    with-proxmox|with_proxmox|proxmox|pve)
      printf 'with-proxmox\n'
      return 0
      ;;
    "")
      provider="$(printf '%s' "${BEAGLE_SERVER_HOST_PROVIDER:-proxmox}" | tr '[:upper:]' '[:lower:]')"
      case "$provider" in
        beagle)
          printf 'standalone\n'
          ;;
        ""|pve|proxmox)
          printf 'with-proxmox\n'
          ;;
        *)
          printf '%s\n' "$provider"
          ;;
      esac
      return 0
      ;;
    *)
      printf '%s\n' "$mode"
      ;;
  esac
}

install_mode_label() {
  case "$(install_mode_kind)" in
    standalone)
      printf 'Beagle OS standalone\n'
      ;;
    with-proxmox)
      printf 'Beagle OS with Proxmox\n'
      ;;
    *)
      printf 'unknown\n'
      ;;
  esac
}

host_provider_kind() {
  case "$(install_mode_kind)" in
    standalone)
      printf 'beagle\n'
      ;;
    with-proxmox)
      printf 'proxmox\n'
      ;;
    *)
      printf 'unsupported\n'
      ;;
  esac
}

prompt_install_mode() {
  local default_mode answer normalized
  default_mode="$(install_mode_kind)"
  if [[ "$default_mode" != "standalone" && "$default_mode" != "with-proxmox" ]]; then
    default_mode="with-proxmox"
  fi
  printf '\nInstall mode:\n' >&2
  printf '1) Beagle OS standalone\n' >&2
  printf '2) Beagle OS with Proxmox\n' >&2
  if [[ "$default_mode" == "standalone" ]]; then
    printf 'Choose install mode [1]: ' >&2
  else
    printf 'Choose install mode [2]: ' >&2
  fi
  IFS= read -r answer || true
  answer="${answer//$'\r'/}"
  case "${answer:-}" in
    "")
      normalized="$default_mode"
      ;;
    1)
      normalized="standalone"
      ;;
    2)
      normalized="with-proxmox"
      ;;
    *)
      BEAGLE_SERVER_INSTALL_MODE="$answer"
      normalized="$(install_mode_kind)"
      ;;
  esac
  case "$normalized" in
    standalone|with-proxmox)
      BEAGLE_SERVER_INSTALL_MODE="$normalized"
      BEAGLE_SERVER_HOST_PROVIDER="$(host_provider_kind)"
      return 0
      ;;
    *)
      echo "Unsupported server-installer install mode: ${answer:-$default_mode}" >&2
      exit 1
      ;;
  esac
}

require_supported_server_target() {
  local mode kind
  mode="$(install_mode_kind)"
  kind="$(host_provider_kind)"
  case "$mode:$kind" in
    standalone:beagle|with-proxmox:proxmox)
      return 0
      ;;
    *)
      echo "Unsupported server-installer mode/provider combination: mode=$mode provider=$kind" >&2
      exit 1
      ;;
  esac
}

validate_hostname() {
  [[ "$1" =~ ^[a-z0-9][a-z0-9-]{0,62}$ ]]
}

validate_username() {
  [[ "$1" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]]
}

current_live_disks() {
  findmnt -rn -o SOURCE /run/live/medium 2>/dev/null | while read -r source; do
    [[ -n "$source" ]] || continue
    lsblk -no PKNAME "$source" 2>/dev/null | sed 's#^#/dev/#'
    if [[ "$source" == /dev/* ]]; then
      printf '%s\n' "${source%%[0-9]*}"
    fi
  done | awk 'NF && !seen[$0]++'
}

choose_target_disk() {
  local name size model type rm transport device answer label live_flag
  local -a live_disks=()
  local -a preferred_items=()
  local -a fallback_items=()

  mapfile -t live_disks < <(current_live_disks || true)

  while IFS=$'\x1f' read -r name size model type rm transport; do
    [[ "$type" == "disk" ]] || continue
    device="/dev/${name}"
    [[ "$device" == /dev/loop* || "$device" == /dev/sr* || "$device" == /dev/ram* || "$device" == /dev/zram* ]] && continue
    [[ "$device" == /dev/mmcblk*boot* || "$device" == /dev/mmcblk*rpmb* ]] && continue
    live_flag="0"
    if printf '%s\n' "${live_disks[@]}" | grep -Fxq "$device"; then
      live_flag="1"
    fi
    label="${model:-disk} ${size:-unknown} rm=${rm:-0} ${transport:-}"
    log "disk candidate: $device size=${size:-unknown} rm=${rm:-0} transport=${transport:-} live=$live_flag"
    if [[ "${rm:-0}" != "1" && "${transport:-}" != "usb" ]]; then
      preferred_items+=("$device" "$label")
      continue
    fi
    [[ "$live_flag" == "1" ]] && continue
    fallback_items+=("$device" "$label")
  done < <(
    lsblk -Pnd -o NAME,SIZE,MODEL,TYPE,RM,TRAN 2>/dev/null | while IFS= read -r line; do
      eval "$line"
      printf '%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\n' \
        "${NAME:-}" "${SIZE:-}" "${MODEL:-}" "${TYPE:-}" "${RM:-0}" "${TRAN:-}"
    done
  )

  if (( ${#preferred_items[@]} == 0 )); then
    preferred_items=("${fallback_items[@]}")
  fi

  if (( ${#preferred_items[@]} == 0 )); then
    echo "No writable target disk found." >&2
    exit 1
  fi

  printf '\n[Beagle OS Server Installer]\n' >&2
  printf 'Choose the target disk. It will be erased completely.\n\n' >&2
  local index=1
  while (( index <= ${#preferred_items[@]} / 2 )); do
    printf '%s) %s %s\n' "$index" "${preferred_items[$(( (index - 1) * 2 ))]}" "${preferred_items[$(( (index - 1) * 2 + 1 ))]}" >&2
    index=$((index + 1))
  done
  printf '\nType the number of the target disk and press ENTER: ' >&2
  read -r answer
  answer="${answer//$'\r'/}"
  [[ "$answer" =~ ^[0-9]+$ ]] || {
    echo "Invalid selection: $answer" >&2
    exit 1
  }
  (( answer >= 1 && answer <= ${#preferred_items[@]} / 2 )) || {
    echo "Selection out of range: $answer" >&2
    exit 1
  }
  printf '%s\n' "${preferred_items[$(( (answer - 1) * 2 ))]}"
}

confirm_wipe() {
  local disk="$1"
  local answer=""
  printf '\nTarget disk: %s\n' "$disk"
  printf 'Type YES to erase this disk and continue: '
  read -r answer
  answer="${answer//$'\r'/}"
  [[ "$answer" == "YES" ]]
}

partition_suffix() {
  local disk="$1"
  local part="$2"
  case "$disk" in
    /dev/nvme*|/dev/mmcblk*) printf '%sp%s\n' "$disk" "$part" ;;
    *) printf '%s%s\n' "$disk" "$part" ;;
  esac
}

wait_for_network() {
  local iface attempt=0 max_attempts=30
  iface="${PRIMARY_IFACE:-$(detect_primary_iface || true)}"

  ensure_live_dns
  if [[ -n "$iface" ]] && ! iface_has_ipv4 "$iface"; then
    renew_live_dhcp_lease "$iface"
  fi

  printf 'Waiting for network...' >&2
  while (( attempt < max_attempts )); do
    if network_ready "$iface"; then
      printf ' OK\n' >&2
      return 0
    fi
    if (( attempt > 0 && attempt % 5 == 0 )); then
      ensure_live_dns
      if [[ -n "$iface" ]] && ! iface_has_ipv4 "$iface"; then
        renew_live_dhcp_lease "$iface"
      fi
    fi
    printf '.' >&2
    sleep 2
    attempt=$((attempt + 1))
  done
  printf ' FAILED\n' >&2
  echo "Network not available after 60 seconds." >&2
  return 1
}

ensure_live_dns() {
  local resolv_path="${BEAGLE_SERVER_LIVE_RESOLV_CONF:-/etc/resolv.conf}"
  if grep -qE '^\s*nameserver\s+[0-9]' "$resolv_path" 2>/dev/null; then
    return 0
  fi
  printf 'nameserver 1.1.1.1\nnameserver 8.8.8.8\n' >"$resolv_path"
}

iface_has_ipv4() {
  local iface="$1"
  ip -4 addr show dev "$iface" 2>/dev/null | grep -qE 'inet [0-9]'
}

iface_has_default_route() {
  local iface="$1"
  [[ -n "$iface" ]] || return 1
  ip route show default 2>/dev/null | grep -Eq "(^| )dev ${iface}( |$)"
}

renew_live_dhcp_lease() {
  local iface="$1"
  [[ -n "$iface" ]] || return 0
  command -v dhclient >/dev/null 2>&1 || return 0
  log "renewing live DHCP lease on $iface"
  dhclient -4 -nw \
    -pf "/run/dhclient-${iface}.pid" \
    -lf "/run/dhclient-${iface}.leases" \
    "$iface" >>"$LOG_FILE" 2>&1 || true
}

network_ready() {
  local iface="$1"
  ensure_live_dns
  [[ -n "$iface" ]] || return 1
  iface_has_ipv4 "$iface" || return 1
  iface_has_default_route "$iface" || return 1
  getent ahostsv4 deb.debian.org >/dev/null 2>&1 || return 1
  curl -sf -o /dev/null --connect-timeout 3 "https://deb.debian.org/debian/dists/${DEBIAN_RELEASE}/Release" 2>/dev/null
}

run_with_retry() {
  local description="$1"
  shift
  local attempt=1
  local max_attempts="${BEAGLE_SERVER_INSTALL_RETRIES:-3}"
  local delay="${BEAGLE_SERVER_INSTALL_RETRY_DELAY_SECONDS:-5}"
  local rc=1
  while (( attempt <= max_attempts )); do
    log "run[$attempt/$max_attempts]: $description"
    if "$@" >>"$LOG_FILE" 2>&1; then
      return 0
    fi
    rc=$?
    log "retrying after failure rc=$rc: $description"
    wait_for_network || true
    sleep "$delay"
    attempt=$((attempt + 1))
  done
  return "$rc"
}

detect_primary_iface() {
  local iface=""
  iface="$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')"
  if [[ -n "$iface" ]]; then
    printf '%s\n' "$iface"
    return 0
  fi

  ls /sys/class/net | grep -E '^(en|eth)' | head -n 1
}

write_hostname_files() {
  cat >"$TARGET_MOUNT/etc/hostname" <<EOF
$INSTALL_HOSTNAME
EOF
  cat >"$TARGET_MOUNT/etc/hosts" <<EOF
127.0.0.1 localhost
127.0.1.1 $INSTALL_HOSTNAME

::1 localhost ip6-localhost ip6-loopback
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
EOF
}

write_network_config() {
  mkdir -p "$TARGET_MOUNT/etc/network"
  if [[ "$(install_mode_kind)" == "with-proxmox" ]]; then
    cat >"$TARGET_MOUNT/etc/network/interfaces" <<EOF
auto lo
iface lo inet loopback

iface $PRIMARY_IFACE inet manual

auto vmbr0
iface vmbr0 inet dhcp
    bridge-ports $PRIMARY_IFACE
    bridge-stp off
    bridge-fd 0
EOF
    return 0
  fi
  cat >"$TARGET_MOUNT/etc/network/interfaces" <<EOF
auto lo
iface lo inet loopback

auto $PRIMARY_IFACE
iface $PRIMARY_IFACE inet dhcp
EOF
}

write_apt_sources() {
  cat >"$TARGET_MOUNT/etc/apt/sources.list" <<EOF
deb $DEBIAN_MIRROR $DEBIAN_RELEASE main contrib non-free-firmware
deb $DEBIAN_MIRROR ${DEBIAN_RELEASE}-updates main contrib non-free-firmware
deb $DEBIAN_SECURITY_MIRROR ${DEBIAN_RELEASE}-security main contrib non-free-firmware
EOF

  write_provider_apt_sources
}

write_provider_apt_sources() {
  local kind
  kind="$(host_provider_kind)"
  mkdir -p "$TARGET_MOUNT/etc/apt/sources.list.d" "$TARGET_MOUNT/usr/share/keyrings"
  case "$kind" in
    beagle)
      return 0
      ;;
    proxmox)
      run_logged curl -fsSL "$PROXMOX_KEY_URL" -o "$TARGET_MOUNT/usr/share/keyrings/proxmox-archive-keyring.gpg"
      cat >"$TARGET_MOUNT/etc/apt/sources.list.d/proxmox.list" <<EOF
deb [signed-by=/usr/share/keyrings/proxmox-archive-keyring.gpg] $PROXMOX_REPO_URL $PROXMOX_REPO_SUITE $PROXMOX_REPO_COMPONENT
EOF
      ;;
    *)
      echo "Unsupported server-installer host provider: $kind" >&2
      exit 1
      ;;
  esac
}

mount_chroot_fs() {
  mount --bind /dev "$TARGET_MOUNT/dev"
  mount -t devpts devpts "$TARGET_MOUNT/dev/pts"
  mount -t proc proc "$TARGET_MOUNT/proc"
  mount -t sysfs sysfs "$TARGET_MOUNT/sys"
  mount --bind /run "$TARGET_MOUNT/run"
  cp /etc/resolv.conf "$TARGET_MOUNT/etc/resolv.conf" 2>/dev/null || true
}

chroot_run() {
  chroot "$TARGET_MOUNT" /usr/bin/env DEBIAN_FRONTEND=noninteractive bash -lc "$*"
}

chroot_run_with_retry() {
  local description="$1"
  local command="$2"
  local attempt=1
  local max_attempts="${BEAGLE_SERVER_INSTALL_RETRIES:-3}"
  local delay="${BEAGLE_SERVER_INSTALL_RETRY_DELAY_SECONDS:-5}"
  local rc=1
  while (( attempt <= max_attempts )); do
    cp /etc/resolv.conf "$TARGET_MOUNT/etc/resolv.conf" 2>/dev/null || true
    log "chroot[$attempt/$max_attempts]: $description"
    if chroot_run "$command" >>"$LOG_FILE" 2>&1; then
      return 0
    fi
    rc=$?
    log "retrying after failure rc=$rc: $description"
    wait_for_network || true
    sleep "$delay"
    attempt=$((attempt + 1))
  done
  return "$rc"
}

write_fstab() {
  local boot_part="$1"
  local root_part="$2"
  local root_uuid boot_uuid
  root_uuid="$(blkid -s UUID -o value "$root_part")"
  boot_uuid="$(blkid -s UUID -o value "$boot_part")"
  cat >"$TARGET_MOUNT/etc/fstab" <<EOF
UUID=$root_uuid / ext4 defaults 0 1
UUID=$boot_uuid /boot/efi vfat umask=0077 0 1
EOF
}

install_base_system() {
  log "running debootstrap for $DEBIAN_RELEASE"
  run_with_retry "debootstrap --arch amd64 $DEBIAN_RELEASE $TARGET_MOUNT $DEBIAN_MIRROR" \
    debootstrap --arch amd64 "$DEBIAN_RELEASE" "$TARGET_MOUNT" "$DEBIAN_MIRROR"
  mkdir -p "$TARGET_MOUNT/etc"
  cp /etc/resolv.conf "$TARGET_MOUNT/etc/resolv.conf"
}

configure_base_system() {
  write_hostname_files
  write_network_config
  write_apt_sources
  write_fstab "$1" "$2"
  mkdir -p "$TARGET_MOUNT/etc/default"
  cat >"$TARGET_MOUNT/etc/default/locale" <<'EOF'
LANG=en_US.UTF-8
LANGUAGE=en_US:en
EOF
}

install_target_packages() {
  local hostname_q username_q password_q
  printf -v hostname_q '%q' "$INSTALL_HOSTNAME"
  printf -v username_q '%q' "$INSTALL_USERNAME"
  printf -v password_q '%q' "$INSTALL_PASSWORD"
  chroot_run_with_retry "apt-get update" "apt-get update"
  chroot_run "printf 'postfix postfix/mailname string %s\n' $hostname_q | debconf-set-selections"
  chroot_run "printf 'postfix postfix/main_mailer_type string Local only\n' | debconf-set-selections"
  install_host_provider_packages
  chroot_run "sed -i 's/^# *en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen || true"
  chroot_run "grep -q '^en_US.UTF-8 UTF-8' /etc/locale.gen || echo 'en_US.UTF-8 UTF-8' >> /etc/locale.gen"
  chroot_run "locale-gen en_US.UTF-8"
  chroot_run "update-locale LANG=en_US.UTF-8 LANGUAGE=en_US:en"
  chroot_run "printf 'root:%s\n' $password_q | chpasswd"
  chroot_run "id $username_q >/dev/null 2>&1 || useradd -m -s /bin/bash -G sudo $username_q"
  chroot_run "printf '%s:%s\n' $username_q $password_q | chpasswd"
}

install_host_provider_packages() {
  local kind
  kind="$(host_provider_kind)"
  case "$kind" in
    beagle)
      chroot_run_with_retry \
        "install standalone host packages" \
        "apt-get install -y locales sudo curl ca-certificates gnupg wget ifupdown2 openssh-server git python3 rsync grub-pc grub-efi-amd64-bin efibootmgr dosfstools"
      ;;
    proxmox)
      chroot_run_with_retry \
        "install proxmox host packages" \
        "apt-get install -y locales sudo curl ca-certificates gnupg wget ifupdown2 openssh-server proxmox-ve postfix open-iscsi chrony git python3 rsync grub-pc grub-efi-amd64-bin efibootmgr dosfstools"
      ;;
    *)
      echo "Unsupported server-installer host provider: $kind" >&2
      exit 1
      ;;
  esac
}

install_beagle_host_stack() {
  local kind mode
  local source_url_q install_dir_q hostname_q public_updates_q web_ui_q mode_q
  kind="$(host_provider_kind)"
  mode="$(install_mode_kind)"
  printf -v source_url_q '%q' "$BEAGLE_SOURCE_URL"
  printf -v install_dir_q '%q' "$BEAGLE_INSTALL_DIR"
  printf -v hostname_q '%q' "$INSTALL_HOSTNAME"
  printf -v public_updates_q '%q' "$BEAGLE_PUBLIC_UPDATE_BASE_URL"
  printf -v web_ui_q '%q' "https://$INSTALL_HOSTNAME"
  printf -v mode_q '%q' "$mode"
  chroot_run "mkdir -p /usr/local/src/beagle-os /var/lib/beagle"
  chroot_run_with_retry "download beagle source archive" "curl -fsSL $source_url_q -o /tmp/beagle-os.tar.gz"
  chroot_run "tar -xzf /tmp/beagle-os.tar.gz -C /usr/local/src/beagle-os"
  chroot_run "cd /usr/local/src/beagle-os && BEAGLE_INSTALL_NONINTERACTIVE='1' INSTALL_DIR=$install_dir_q BEAGLE_SERVER_INSTALL_MODE=$mode_q BEAGLE_HOST_PROVIDER=$kind PVE_DCV_PROXY_SERVER_NAME=$hostname_q BEAGLE_WEB_UI_URL=$web_ui_q PVE_DCV_PROXY_LISTEN_PORT='8443' BEAGLE_SITE_PORT='443' BEAGLE_PUBLIC_UPDATE_BASE_URL=$public_updates_q ./scripts/install-beagle-host.sh"
}

install_bootloader() {
  local disk="$1"
  chroot_run "grub-install --target=i386-pc --recheck '$disk' || true"
  chroot_run "grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=debian --recheck --no-nvram"
  chroot_run "update-grub"
}

finish_install() {
  touch "$DONE_FILE"
  printf '\nInstallation complete.\n\nRemove the USB stick and press ENTER to reboot.\n'
  read -r _
  reboot
}

main() {
  require_root
  setup_logging

  printf '\nBeagle OS Server Installer\n'
  printf 'This will install Debian and the Beagle host stack.\n'
  printf 'You can choose between a standalone Beagle host and a Proxmox-backed Beagle host.\n\n'

  prompt_install_mode
  require_supported_server_target
  log "install mode: $(install_mode_kind)"
  log "host provider: $(host_provider_kind)"
  printf 'Selected mode: %s\n\n' "$(install_mode_label)"

  INSTALL_HOSTNAME="$(normalize_hostname "$(prompt_value 'Server hostname' 'beagle-host')")"
  validate_hostname "$INSTALL_HOSTNAME" || {
    echo "Hostname must contain only lowercase letters, digits, and hyphens." >&2
    exit 1
  }
  INSTALL_USERNAME="$(prompt_value 'Linux username' 'beagle')"
  validate_username "$INSTALL_USERNAME" || {
    echo "Linux username contains unsupported characters." >&2
    exit 1
  }
  INSTALL_PASSWORD="$(prompt_password)"
  INSTALL_DISK="$(choose_target_disk)"
  confirm_wipe "$INSTALL_DISK" || {
    echo "Installation cancelled."
    exit 1
  }

  PRIMARY_IFACE="$(detect_primary_iface)"
  [[ -n "$PRIMARY_IFACE" ]] || {
    echo "No primary network interface found." >&2
    exit 1
  }

  local bios_part boot_part root_part
  bios_part="$(partition_suffix "$INSTALL_DISK" 1)"
  boot_part="$(partition_suffix "$INSTALL_DISK" 2)"
  root_part="$(partition_suffix "$INSTALL_DISK" 3)"

  mkdir -p "$TARGET_MOUNT" "$EFI_MOUNT"
  run_logged wipefs -a "$INSTALL_DISK"
  run_logged parted -s "$INSTALL_DISK" mklabel gpt
  run_logged parted -s "$INSTALL_DISK" mkpart BIOSBOOT 1MiB 3MiB
  run_logged parted -s "$INSTALL_DISK" set 1 bios_grub on
  run_logged parted -s "$INSTALL_DISK" mkpart ESP fat32 3MiB 1027MiB
  run_logged parted -s "$INSTALL_DISK" set 2 esp on
  run_logged parted -s "$INSTALL_DISK" set 2 boot on
  run_logged parted -s "$INSTALL_DISK" mkpart primary ext4 1027MiB 100%
  run_logged partprobe "$INSTALL_DISK"
  run_logged udevadm settle
  run_logged mkfs.vfat -F 32 -n BEAGLEBOOT "$boot_part"
  run_logged mkfs.ext4 -F -L BEAGLEROOT "$root_part"
  run_logged mount "$root_part" "$TARGET_MOUNT"
  mkdir -p "$EFI_MOUNT"
  run_logged mount "$boot_part" "$EFI_MOUNT"

  wait_for_network
  install_base_system
  configure_base_system "$boot_part" "$root_part"
  mount_chroot_fs
  install_target_packages
  install_beagle_host_stack
  install_bootloader "$INSTALL_DISK"
  finish_install
}

main "$@"
