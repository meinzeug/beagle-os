#!/usr/bin/env bash
set -euo pipefail

THINCLIENT_ARCH="${THINCLIENT_ARCH:-amd64}"
THINCLIENT_LINUX_FLAVOUR="${THINCLIENT_LINUX_FLAVOUR:-}"

if [[ -z "$THINCLIENT_LINUX_FLAVOUR" ]]; then
  case "$THINCLIENT_ARCH" in
    amd64) THINCLIENT_LINUX_FLAVOUR="amd64" ;;
    *)
      echo "Unsupported THINCLIENT_ARCH: $THINCLIENT_ARCH" >&2
      exit 1
      ;;
  esac
fi

BOOT_ARGS="boot=live components username=thinclient hostname=beagle-installer ip=dhcp quiet loglevel=3 systemd.show_status=0 vt.global_cursor_default=0 splash plymouth.ignore-serial-consoles pve_thin_client.mode=installer"

BOOTLOADER_FLAG="--bootloader"
BOOTLOADER_VALUE="grub"

if lb config --help 2>/dev/null | grep -q -- '--bootloaders'; then
  BOOTLOADER_FLAG="--bootloaders"
  BOOTLOADER_VALUE="grub-pc"
fi

lb config noauto \
  --mode debian \
  --architectures "$THINCLIENT_ARCH" \
  --initsystem systemd \
  --distribution bookworm \
  --binary-images iso-hybrid \
  --debian-installer none \
  --apt-recommends false \
  --archive-areas "main contrib non-free non-free-firmware" \
  --linux-packages "none" \
  --linux-flavours "$THINCLIENT_LINUX_FLAVOUR" \
  --firmware-chroot true \
  --firmware-binary true \
  --mirror-bootstrap "https://deb.debian.org/debian" \
  --mirror-chroot "https://deb.debian.org/debian" \
  --mirror-binary "https://deb.debian.org/debian" \
  --mirror-chroot-security "https://deb.debian.org/debian-security" \
  --mirror-binary-security "https://deb.debian.org/debian-security" \
  --security false \
  "$BOOTLOADER_FLAG" "$BOOTLOADER_VALUE" \
  --bootappend-live "$BOOT_ARGS" \
  "$@"
