#!/bin/sh
set -eu

LOG_DIR="${PVE_THIN_CLIENT_X11_LOG_DIR:-}"
LOG_FILE=""
CMDLINE_FILE="${PVE_THIN_CLIENT_CMDLINE_FILE:-/proc/cmdline}"
TRACE_FILE="${PVE_THIN_CLIENT_TRACE_FILE:-${XDG_RUNTIME_DIR:-/tmp}/pve-thin-client-runtime-trace.log}"

trace_event() {
  phase="$1"
  shift || true
  trace_dir="$(dirname "$TRACE_FILE")"
  mkdir -p "$trace_dir" >/dev/null 2>&1 || true
  printf '[%s] phase=%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$phase" "$*" >>"$TRACE_FILE" 2>/dev/null || true
}

setup_logging() {
  for candidate in \
    "${LOG_DIR}" \
    "/tmp/pve-thin-client-logs" \
    "${XDG_RUNTIME_DIR:-/run/user/1000}/pve-thin-client" \
    "/home/thinclient/.cache/pve-thin-client"
  do
    [ -n "$candidate" ] || continue
    if mkdir -p "$candidate" >/dev/null 2>&1 && touch "$candidate/start-x11.log" >/dev/null 2>&1; then
      chmod 0644 "$candidate/start-x11.log" >/dev/null 2>&1 || true
      LOG_DIR="$candidate"
      LOG_FILE="$candidate/start-x11.log"
      exec >>"$LOG_FILE" 2>&1
      return 0
    fi
  done
  return 1
}

setup_logging || true

ensure_xauth_context() {
  home_dir="${HOME:-/home/thinclient}"
  mkdir -p "$home_dir" >/dev/null 2>&1 || true
  export HOME="$home_dir"
  export XAUTHORITY="${XAUTHORITY:-$home_dir/.Xauthority}"
  touch "$XAUTHORITY" >/dev/null 2>&1 || true
  chmod 0600 "$XAUTHORITY" >/dev/null 2>&1 || true
}

ensure_xauth_context

if [ -r "${CMDLINE_FILE}" ] && grep -Eq '(^|[[:space:]])pve_thin_client\.installer_ui=text($|[[:space:]])' "${CMDLINE_FILE}"; then
  echo "[start-x11] text installer mode detected, skipping X startup"
  trace_event "x11.skip" "reason=text-installer"
  exit 0
fi
if [ -r "${CMDLINE_FILE}" ] && grep -Eq '(^|[[:space:]])pve_thin_client\.(no_x11|no_auto_x11)=1($|[[:space:]])' "${CMDLINE_FILE}"; then
  echo "[start-x11] no-x cmdline flag detected, skipping X startup"
  trace_event "x11.skip" "reason=no-x-cmdline"
  exit 0
fi

echo "[start-x11] $(date -Is 2>/dev/null || date) starting X session launcher"
if [ -n "${LOG_FILE}" ]; then
  echo "[start-x11] log file: ${LOG_FILE}"
else
  echo "[start-x11] log file unavailable, using current tty/stdout"
fi

wait_for_graphics() {
  timeout="${PVE_THIN_CLIENT_DRI_WAIT_SECONDS:-20}"
  counter=0

  if [ -e /dev/dri/card0 ] || [ -e /dev/dri/renderD128 ]; then
    return 0
  fi

  if command -v udevadm >/dev/null 2>&1; then
    udevadm settle --timeout="$timeout" >/dev/null 2>&1 || true
  fi

  while [ "$counter" -lt "$timeout" ]; do
    if [ -e /dev/dri/card0 ] || [ -e /dev/dri/renderD128 ]; then
      return 0
    fi
    sleep 1
    counter=$((counter + 1))
  done

  return 0
}

clear_stale_x_locks() {
  rm -f /tmp/.X0-lock >/dev/null 2>&1 || true
  rm -f /tmp/.X11-unix/X0 >/dev/null 2>&1 || true
}

launch_x_once() {
  echo "[start-x11] invoking startx (attempt=${1:-1})"
  trace_event "x11.start" "launcher=pve-thin-client-start-x11 attempt=${1:-1}"
  if command -v xauth >/dev/null 2>&1 && command -v mcookie >/dev/null 2>&1; then
    cookie="$(mcookie)"
    xauth -f "$XAUTHORITY" remove :0 >/dev/null 2>&1 || true
    xauth -f "$XAUTHORITY" remove unix:0 >/dev/null 2>&1 || true
    xauth -f "$XAUTHORITY" add :0 . "$cookie" >/dev/null 2>&1 || true
    xauth -f "$XAUTHORITY" add unix:0 . "$cookie" >/dev/null 2>&1 || true
  fi
  exec xinit /usr/local/bin/start-pve-thin-client-session -- /usr/bin/X :0 vt1 -keeptty -nolisten tcp -auth "$XAUTHORITY"
}

wait_for_graphics
clear_stale_x_locks

attempt=1
while [ "$attempt" -le 2 ]; do
  if launch_x_once "$attempt"; then
    echo "[start-x11] X session exited normally"
    trace_event "x11.exit" "status=0"
    exit 0
  fi
  status=$?
  echo "[start-x11] startx failed with status=$status (attempt=$attempt)"
  trace_event "x11.failed" "status=$status attempt=$attempt"
  clear_stale_x_locks
  attempt=$((attempt + 1))
  sleep 1
done

echo "[start-x11] giving up after retries"
trace_event "x11.give-up" "status=$status"
exit "$status"
