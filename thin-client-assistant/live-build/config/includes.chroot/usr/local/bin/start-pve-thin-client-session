#!/bin/sh
set -eu

BOOT_MODE="${PVE_THIN_CLIENT_BOOT_MODE:-$(/usr/local/bin/pve-thin-client-boot-mode 2>/dev/null || printf runtime)}"
export DISPLAY="${DISPLAY:-:0}"
export HOME="${HOME:-/home/thinclient}"
HOST_TAG="$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf thinclient)"
HOST_TAG="$(printf '%s' "$HOST_TAG" | tr -cs 'A-Za-z0-9._-' '-')"
BOOT_STAMP="$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null || date +%Y%m%dT%H%M%SZ)"
LOG_SESSION_ID="${PVE_THIN_CLIENT_LOG_SESSION_ID:-${BOOT_STAMP}-${BOOT_MODE}-${HOST_TAG}}"
LOG_ROOT="${PVE_THIN_CLIENT_LOG_ROOT:-/tmp/pve-thin-client-logs}"
LOG_DIR="${PVE_THIN_CLIENT_LOG_DIR:-$LOG_ROOT/$LOG_SESSION_ID}"
LOCK_SCREEN_SCRIPT="${PVE_THIN_CLIENT_LOCK_SCREEN_SCRIPT:-/usr/local/lib/pve-thin-client/runtime/device_lock_screen.sh}"
mkdir -p "$LOG_DIR"
export PVE_THIN_CLIENT_LOG_DIR="$LOG_DIR"
export PVE_THIN_CLIENT_LOG_SESSION_ID="$LOG_SESSION_ID"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

{
  printf 'BOOT_MODE=%s\n' "$BOOT_MODE"
  printf 'HOSTNAME=%s\n' "$HOST_TAG"
  printf 'LOG_SESSION_ID=%s\n' "$LOG_SESSION_ID"
  printf 'LOG_DIR=%s\n' "$LOG_DIR"
  printf 'DATE=%s\n' "$(date -Is 2>/dev/null || date)"
} >"$LOG_DIR/session.env" 2>&1 || true

{
  echo "=== date ==="
  date -Is 2>/dev/null || date
  echo
  echo "=== boot mode ==="
  printf '%s\n' "$BOOT_MODE"
  echo
  echo "=== /proc/cmdline ==="
  cat /proc/cmdline 2>/dev/null || true
  echo
  echo "=== findmnt ==="
  findmnt -rn -o TARGET,SOURCE,FSTYPE,OPTIONS 2>/dev/null || true
  echo
  echo "=== lsblk ==="
  lsblk -e7 -o NAME,PATH,SIZE,TYPE,FSTYPE,LABEL,UUID,RM,TRAN,MOUNTPOINTS 2>/dev/null || true
  echo
  echo "=== blkid ==="
  blkid 2>/dev/null || true
} >>"$LOG_DIR/boot-session.log" 2>&1 || true

normalize_xauthority_aliases() {
  local serverauth=""
  local cookie=""
  local hostname_short=""
  local hostname_fqdn=""
  local entry=""

  command -v xauth >/dev/null 2>&1 || return 0
  touch "$XAUTHORITY" >/dev/null 2>&1 || return 0
  chmod 0600 "$XAUTHORITY" >/dev/null 2>&1 || true

  for serverauth in /tmp/serverauth.*; do
    [ -f "$serverauth" ] || continue
    cookie="$(xauth -f "$serverauth" list 2>/dev/null | awk 'NR==1 {print $3}')"
    [ -n "$cookie" ] && break
  done

  if [ -z "$cookie" ]; then
    cookie="$(xauth -f "$XAUTHORITY" list 2>/dev/null | awk 'NR==1 {print $3}')"
  fi
  [ -n "$cookie" ] || return 0

  hostname_short="$(hostname 2>/dev/null || printf '')"
  hostname_fqdn="$(hostname -f 2>/dev/null || printf '%s' "$hostname_short")"

  for entry in \
    ":0" \
    "unix:0" \
    "localhost/unix:0" \
    "localhost.localdomain/unix:0" \
    "${hostname_short}/unix:0" \
    "${hostname_fqdn}/unix:0"
  do
    [ -n "$entry" ] || continue
    xauth -f "$XAUTHORITY" remove "$entry" >/dev/null 2>&1 || true
    xauth -f "$XAUTHORITY" add "$entry" MIT-MAGIC-COOKIE-1 "$cookie" >/dev/null 2>&1 || true
  done
}

wait_for_session_display() {
  attempt=1
  attempts="${PVE_THIN_CLIENT_X11_READY_RETRIES:-20}"

  if ! command -v xset >/dev/null 2>&1; then
    return 0
  fi

  while [ "$attempt" -le "$attempts" ]; do
    if DISPLAY="$DISPLAY" XAUTHORITY="$XAUTHORITY" xset q >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    attempt=$((attempt + 1))
  done

  return 1
}

allow_local_x_clients() {
  attempt=1
  attempts="${PVE_THIN_CLIENT_XHOST_RETRIES:-10}"

  command -v xhost >/dev/null 2>&1 || return 0

  while [ "$attempt" -le "$attempts" ]; do
    if DISPLAY="$DISPLAY" XAUTHORITY="$XAUTHORITY" xhost +SI:localuser:thinclient >/dev/null 2>&1 &&
       DISPLAY="$DISPLAY" XAUTHORITY="$XAUTHORITY" xhost +local: >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    attempt=$((attempt + 1))
  done

  return 1
}

wait_for_session_display || true
normalize_xauthority_aliases

if command -v xsetroot >/dev/null 2>&1; then
  xsetroot -solid "#050816" >/dev/null 2>&1 || true
fi

background_image="/usr/local/share/beagle-os/beagleos.png"
client_mode="$(sed -n 's/.*pve_thin_client\.client_mode=\([^ ]*\).*/\1/p' /proc/cmdline 2>/dev/null | head -n 1)"
client_mode_normalized="$(printf '%s' "$client_mode" | tr '[:upper:]' '[:lower:]')"
case "$client_mode_normalized" in
  gaming|gfn|geforcenow|geforce-now)
    if [ -f /usr/local/share/beagle-os/beagleos-gaming.png ]; then
      background_image="/usr/local/share/beagle-os/beagleos-gaming.png"
    fi
    ;;
esac

if command -v feh >/dev/null 2>&1 && [ -f "$background_image" ]; then
  feh --no-fehbg --image-bg black --bg-fill "$background_image" >/dev/null 2>&1 || true
fi

if command -v xset >/dev/null 2>&1; then
  xset -dpms >/dev/null 2>&1 || true
  xset s off >/dev/null 2>&1 || true
  xset s noblank >/dev/null 2>&1 || true
fi

allow_local_x_clients || true

if command -v openbox-session >/dev/null 2>&1; then
  openbox-session >"$LOG_DIR/openbox.log" 2>&1 &
fi

if [ "${BOOT_MODE}" = "installer" ]; then
  if [ -x /usr/local/bin/pve-thin-client-live-menu ]; then
    exec /usr/local/bin/pve-thin-client-live-menu >>"$LOG_DIR/live-menu-launch.log" 2>&1
  fi
fi

if [ -x /usr/local/bin/pve-thin-client-display-init ]; then
  /usr/local/bin/pve-thin-client-display-init >"$LOG_DIR/display-init.log" 2>&1 || true
fi

if [ -x /usr/local/bin/pve-thin-client-audio-init ]; then
  /usr/local/bin/pve-thin-client-audio-init >"$LOG_DIR/audio-init.log" 2>&1 || true
  pkill -f '^bash /usr/local/bin/pve-thin-client-audio-init --watch' >/dev/null 2>&1 || true
  /usr/local/bin/pve-thin-client-audio-init --watch "${PVE_THIN_CLIENT_AUDIO_WATCH_LOOPS:-0}" >"$LOG_DIR/audio-watch.log" 2>&1 &
fi

if [ -x /usr/local/sbin/beagle-update-client ]; then
  /usr/local/sbin/beagle-update-client session-start >"$LOG_DIR/update-session.log" 2>&1 &
  /usr/local/sbin/beagle-update-client session-monitor >"$LOG_DIR/update-monitor.log" 2>&1 &
fi

if [ -r "$LOCK_SCREEN_SCRIPT" ]; then
  /bin/bash -lc ". \"$LOCK_SCREEN_SCRIPT\" && run_device_lock_screen_watcher" >"$LOG_DIR/lock-screen.log" 2>&1 &
fi

# prepare-runtime already ran as root via systemd before the session starts.
# Re-running it here through sudo causes password prompts and boot delays.

if /usr/local/lib/pve-thin-client/runtime/launch-session.sh >>"$LOG_DIR/runtime-session.log" 2>&1; then
  exit 0
else
  status=$?
fi
printf '\n[thinclient] runtime launcher exited with status %s\n' "$status" >>"$LOG_DIR/runtime-session.log" 2>&1 || true

if [ "${BOOT_MODE}" = "runtime" ]; then
  exit "$status"
fi

if command -v xterm >/dev/null 2>&1; then
  exec xterm -T "Thinclient Session Failed" -fa Monospace -fs 11 -fg white -bg black -hold \
    -e /bin/sh -lc "echo 'Thinclient session start failed.'; echo 'Use the Beagle Manager or Beagle UI to inspect device credentials.'; echo; tail -n 200 '$LOG_DIR/runtime-session.log' 2>/dev/null || true; echo; exec /bin/bash"
fi

exec /bin/bash
