#!/usr/bin/env bash
set -euo pipefail

audio_log_dir() {
  printf '%s\n' "${PVE_THIN_CLIENT_AUDIO_LOG_DIR:-${PVE_THIN_CLIENT_LOG_DIR:-${HOME:-/tmp}/.cache/beagle-os}/audio}"
}

ensure_audio_log_dir() {
  local dir
  dir="$(audio_log_dir)"
  mkdir -p "$dir" >/dev/null 2>&1 || true
  printf '%s\n' "$dir"
}

start_background_process() {
  local name="$1"
  local log_name="$2"
  shift 2
  local log_dir log_file

  if pgrep -u "$(id -u)" -x "$name" >/dev/null 2>&1; then
    return 0
  fi

  log_dir="$(ensure_audio_log_dir)"
  log_file="$log_dir/$log_name"
  nohup "$@" >>"$log_file" 2>&1 </dev/null &
}

start_wireplumber_session() {
  local log_dir log_file runtime_dir runtime_home display

  if pgrep -u "$(id -u)" -x wireplumber >/dev/null 2>&1; then
    return 0
  fi

  runtime_home="${HOME:-/home/thinclient}"
  runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  display="${DISPLAY:-:0}"
  log_dir="$(ensure_audio_log_dir)"
  log_file="$log_dir/wireplumber.log"

  nohup dbus-run-session -- sh -lc \
    "export HOME='$runtime_home'; export XDG_RUNTIME_DIR='$runtime_dir'; export DISPLAY='$display'; exec wireplumber" \
    >>"$log_file" 2>&1 </dev/null &
}

ensure_audio_stack() {
  export HOME="${HOME:-/home/thinclient}"
  export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  mkdir -p "$XDG_RUNTIME_DIR" >/dev/null 2>&1 || true
  ensure_audio_log_dir >/dev/null 2>&1 || true

  command -v pipewire >/dev/null 2>&1 || return 0

  if ! pgrep -u "$(id -u)" -x pipewire >/dev/null 2>&1; then
    start_background_process pipewire pipewire.log pipewire
    sleep 1
  fi

  if command -v pipewire-pulse >/dev/null 2>&1 && ! pgrep -u "$(id -u)" -x pipewire-pulse >/dev/null 2>&1; then
    start_background_process pipewire-pulse pipewire-pulse.log pipewire-pulse
    sleep 1
  fi

  if command -v wireplumber >/dev/null 2>&1 && ! pgrep -u "$(id -u)" -x wireplumber >/dev/null 2>&1; then
    start_wireplumber_session
    sleep 1
  fi
}

alsa_default_file() {
  printf '%s\n' "${HOME:-/tmp}/.asoundrc"
}

alsa_pcm_candidates() {
  if [[ -r /proc/asound/pcm ]]; then
    awk '
      /playback [1-9]/ {
        split($1, id, "-")
        card = id[1] + 0
        dev = substr(id[2], 1, 2) + 0
        line = tolower($0)
        score = 10
        if (line ~ /analog/) score += 100
        if (line ~ /speaker|headphone|line/) score += 40
        if (line ~ /hdmi|displayport|dp/) score -= 80
        printf "%d %d %d\n", score, card, dev
      }
    ' /proc/asound/pcm | sort -rn
  fi
}

select_default_pcm() {
  local row score card dev

  while read -r score card dev; do
    [[ -n "${card:-}" && -n "${dev:-}" ]] || continue
    printf '%s,%s\n' "$card" "$dev"
    return 0
  done < <(alsa_pcm_candidates)

  printf '0,0\n'
}

write_alsa_default() {
  local selection card dev target
  target="$(alsa_default_file)"

  if [[ -r /usr/share/alsa/alsa.conf.d/99-pipewire-default.conf || -r /etc/alsa/conf.d/99-pipewire-default.conf ]]; then
    cat >"$target" <<'EOF'
# Generated by pve-thin-client-audio-init
pcm.!default {
  type pipewire
  playback_node "-1"
  capture_node "-1"
}
ctl.!default {
  type pipewire
}
EOF
    return 0
  fi

  selection="$(select_default_pcm)"
  card="${selection%,*}"
  dev="${selection#*,}"

  cat >"$target" <<EOF
# Generated by pve-thin-client-audio-init
pcm.!default {
  type plug
  slave.pcm "hw:${card},${dev}"
}
ctl.!default {
  type hw
  card ${card}
}
EOF
}

alsa_card_candidates() {
  if command -v aplay >/dev/null 2>&1; then
    aplay -l 2>/dev/null | awk '
      /^card [0-9]+:/ {
        card=$2
        sub(":", "", card)
        print card
      }
    ' | awk '!seen[$0]++'
  fi
}

configure_alsa_card() {
  local card="$1"

  command -v amixer >/dev/null 2>&1 || return 0

  amixer -c "$card" sset 'Auto-Mute Mode' Disabled >/dev/null 2>&1 || true
  amixer -c "$card" sset Master 100% unmute >/dev/null 2>&1 || true
  amixer -c "$card" sset Speaker 100% unmute >/dev/null 2>&1 || true
  amixer -c "$card" sset Headphone 100% unmute >/dev/null 2>&1 || true
  amixer -c "$card" sset PCM 100% >/dev/null 2>&1 || true
}

configure_alsa() {
  local card configured=0

  write_alsa_default

  for card in $(alsa_card_candidates); do
    configure_alsa_card "$card"
    configured=1
  done

  if [[ "$configured" == "0" ]]; then
    configure_alsa_card 0 || true
    configure_alsa_card 1 || true
  fi
}

sink_exists() {
  local sink_name="${1:-}"
  [[ -n "$sink_name" ]] || return 1
  pactl list short sinks 2>/dev/null | awk '{print $2}' | grep -Fxq "$sink_name"
}

select_sink() {
  local configured="${PVE_THIN_CLIENT_AUDIO_SINK:-}"
  local candidate=""

  if sink_exists "$configured"; then
    printf '%s\n' "$configured"
    return 0
  fi

  candidate="$(pactl list short sinks 2>/dev/null | awk '$5 == "RUNNING" {print $2; exit}')"
  if [[ -n "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$(pactl list short sinks 2>/dev/null | awk '/analog-stereo/ {print $2; exit}')"
  if [[ -n "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  pactl list short sinks 2>/dev/null | awk 'NR==1 {print $2; exit}'
}

sink_active_port() {
  local sink="${1:-}"
  [[ -n "$sink" ]] || return 1

  pactl list sinks 2>/dev/null | awk -v sink="$sink" '
    $1=="Name:" { in_sink=($2==sink) }
    in_sink && $1=="Active" && $2=="Port:" { print $3; exit }
  '
}

sink_port_state() {
  local sink="${1:-}"
  local port="${2:-}"
  [[ -n "$sink" && -n "$port" ]] || return 1

  pactl list sinks 2>/dev/null | awk -v sink="$sink" -v port="$port" '
    $1=="Name:" { in_sink=($2==sink) }
    in_sink && $1==(port ":") {
      line=$0
      if (line ~ /not available/) { print "not available"; exit }
      if (line ~ / available/) { print "available"; exit }
      if (line ~ / unknown/) { print "unknown"; exit }
      print "present"
      exit
    }
  '
}

select_sink_port() {
  local sink="${1:-}"
  local configured="${PVE_THIN_CLIENT_AUDIO_PORT:-}"
  local headphones_state speaker_state active_port
  [[ -n "$sink" ]] || return 0

  if [[ -n "$configured" ]] && [[ -n "$(sink_port_state "$sink" "$configured")" ]]; then
    printf '%s\n' "$configured"
    return 0
  fi

  headphones_state="$(sink_port_state "$sink" "analog-output-headphones" || true)"
  speaker_state="$(sink_port_state "$sink" "analog-output-speaker" || true)"

  if [[ "$headphones_state" == "available" ]]; then
    printf '%s\n' "analog-output-headphones"
    return 0
  fi

  if [[ "$speaker_state" == "available" ]]; then
    printf '%s\n' "analog-output-speaker"
    return 0
  fi

  active_port="$(sink_active_port "$sink" || true)"
  if [[ -n "$active_port" ]]; then
    printf '%s\n' "$active_port"
    return 0
  fi

  if [[ -n "$headphones_state" ]] && [[ "$headphones_state" != "not available" ]]; then
    printf '%s\n' "analog-output-headphones"
    return 0
  fi

  if [[ -n "$speaker_state" ]] && [[ "$speaker_state" != "not available" ]]; then
    printf '%s\n' "analog-output-speaker"
  fi
}

configure_pulse() {
  local sink active_port target_port

  command -v pactl >/dev/null 2>&1 || return 0
  pactl info >/dev/null 2>&1 || return 0

  sink="$(select_sink)"
  [[ -n "$sink" ]] || return 0

  pactl set-default-sink "$sink" >/dev/null 2>&1 || true
  pactl set-sink-mute "$sink" 0 >/dev/null 2>&1 || true
  pactl set-sink-volume "$sink" 100% >/dev/null 2>&1 || true
  target_port="$(select_sink_port "$sink" || true)"
  active_port="$(sink_active_port "$sink" || true)"
  if [[ -n "$target_port" ]] && [[ "$target_port" != "$active_port" ]]; then
    pactl set-sink-port "$sink" "$target_port" >/dev/null 2>&1 || true
  fi

  pactl list short sink-inputs 2>/dev/null | while read -r input_id _; do
    [[ -n "${input_id:-}" ]] || continue
    pactl move-sink-input "$input_id" "$sink" >/dev/null 2>&1 || true
  done
}

wait_for_pulse() {
  local tries="${1:-30}"
  local i

  for i in $(seq 1 "$tries"); do
    if pactl info >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  return 1
}

wait_for_sinks() {
  local tries="${1:-15}"
  local i

  for i in $(seq 1 "$tries"); do
    if pactl list short sinks 2>/dev/null | grep -q .; then
      return 0
    fi
    sleep 1
  done

  return 1
}

watch_mode() {
  local loops="${1:-45}"
  local interval="${PVE_THIN_CLIENT_AUDIO_WATCH_INTERVAL:-1}"
  local wait_tries="$loops"
  local i
  local lock_file="${XDG_RUNTIME_DIR:-/tmp}/pve-thin-client-audio-watch.lock"

  if [[ "$loops" =~ ^[0-9]+$ ]] && [[ "$loops" -eq 0 ]]; then
    wait_tries="${PVE_THIN_CLIENT_AUDIO_WAIT_TRIES:-30}"
  fi

  # Keep exactly one watcher process per user session.
  if command -v flock >/dev/null 2>&1; then
    exec 9>"$lock_file"
    flock -n 9 || exit 0
  fi

  configure_alsa
  ensure_audio_stack
  wait_for_pulse "$wait_tries" || true
  wait_for_sinks "${PVE_THIN_CLIENT_AUDIO_SINK_WAIT_TRIES:-15}" || true

  if [[ "$loops" =~ ^[0-9]+$ ]] && [[ "$loops" -eq 0 ]]; then
    while true; do
      configure_alsa
      ensure_audio_stack
      configure_pulse
      sleep "$interval"
    done
  fi

  for i in $(seq 1 "$loops"); do
    configure_alsa
    ensure_audio_stack
    configure_pulse
    sleep "$interval"
  done
}

main() {
  case "${1:-}" in
    --watch)
      watch_mode "${2:-45}"
      ;;
    *)
      configure_alsa
      ensure_audio_stack
      wait_for_pulse "${PVE_THIN_CLIENT_AUDIO_WAIT_TRIES:-15}" || true
      wait_for_sinks "${PVE_THIN_CLIENT_AUDIO_SINK_WAIT_TRIES:-15}" || true
      configure_pulse
      ;;
  esac
}

main "$@"
