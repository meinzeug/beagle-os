#!/bin/sh
set -eu

DEFAULT_LOG_ROOT="${XDG_RUNTIME_DIR:-$HOME/.cache}/pve-thin-client"
LOG_ROOT="${PVE_THIN_CLIENT_LOG_ROOT:-$DEFAULT_LOG_ROOT}"
LOG_DIR="${PVE_THIN_CLIENT_LOG_DIR:-$LOG_ROOT/kiosk}"
KIOSK_LOG="$LOG_DIR/kiosk-session.log"
BACKGROUND_IMAGE="/usr/local/share/beagle-os/beagleos-gaming.png"
FONTCONFIG_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/fontconfig"

mkdir -p "$LOG_DIR"
chmod 0700 "$LOG_DIR" >/dev/null 2>&1 || true
mkdir -p "$FONTCONFIG_CACHE_DIR" >/dev/null 2>&1 || true

export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export FONTCONFIG_PATH="${FONTCONFIG_PATH:-/etc/fonts}"
export FONTCONFIG_FILE="${FONTCONFIG_FILE:-/etc/fonts/fonts.conf}"
export FONTCONFIG_CACHE="$FONTCONFIG_CACHE_DIR"

if [ -x /usr/local/bin/pve-thin-client-display-init ]; then
  /usr/local/bin/pve-thin-client-display-init >"$LOG_DIR/display-init.log" 2>&1 || true
fi

if [ -x /usr/local/bin/pve-thin-client-audio-init ]; then
  /usr/local/bin/pve-thin-client-audio-init >"$LOG_DIR/audio-init.log" 2>&1 || true
fi

if command -v xsetroot >/dev/null 2>&1; then
  xsetroot -solid "#090a0b" >/dev/null 2>&1 || true
fi

if command -v feh >/dev/null 2>&1 && [ -f "$BACKGROUND_IMAGE" ]; then
  feh --no-fehbg --image-bg black --bg-fill "$BACKGROUND_IMAGE" >/dev/null 2>&1 || true
fi

if command -v xset >/dev/null 2>&1; then
  xset -dpms >/dev/null 2>&1 || true
  xset s off >/dev/null 2>&1 || true
  xset s noblank >/dev/null 2>&1 || true
fi

if command -v openbox-session >/dev/null 2>&1; then
  openbox-session >"$LOG_DIR/openbox.log" 2>&1 &
fi

if [ -x /usr/local/sbin/beagle-update-client ]; then
  /usr/local/sbin/beagle-update-client session-start >"$LOG_DIR/update-session.log" 2>&1 &
  /usr/local/sbin/beagle-update-client session-monitor >"$LOG_DIR/update-monitor.log" 2>&1 &
fi

if [ -x /usr/local/sbin/beagle-kiosk-launch ]; then
  exec /usr/local/sbin/beagle-kiosk-launch >>"$KIOSK_LOG" 2>&1
fi

exec /bin/bash
