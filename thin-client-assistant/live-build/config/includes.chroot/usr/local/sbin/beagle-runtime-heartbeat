#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/beagle-os"
STATUS_FILE="$STATE_DIR/runtime-heartbeat.status"
TRACE_FILE="$STATE_DIR/runtime-trace.log"
PREV_FILE="$STATE_DIR/runtime-heartbeat.prev"
COMMON_SH="/usr/local/lib/pve-thin-client/runtime/common.sh"
DEVICE_SYNC_SH="/usr/local/lib/pve-thin-client/runtime/device_sync.sh"

install -d -m 0755 "$STATE_DIR"

if [[ -r "$COMMON_SH" ]]; then
  # shellcheck disable=SC1090
  source "$COMMON_SH"
  load_runtime_config >/dev/null 2>&1 || true
fi
if [[ -r "$DEVICE_SYNC_SH" ]]; then
  # shellcheck disable=SC1090
  source "$DEVICE_SYNC_SH"
fi

timestamp="$(date -Iseconds 2>/dev/null || date)"

if declare -F beagle_streaming_session_active >/dev/null 2>&1 && beagle_streaming_session_active; then
  if declare -F sync_device_runtime_state >/dev/null 2>&1; then
    sync_device_runtime_state >/dev/null 2>&1 || true
  fi
  {
    printf 'timestamp=%q\n' "$timestamp"
    printf 'streaming=%q\n' "1"
    printf 'suppressed=%q\n' "1"
    printf 'reason=%q\n' "suppressed while GeForce NOW is active"
  } >"$STATUS_FILE"
  exit 0
fi

xorg_state="$(pgrep -f '/usr/lib/xorg/Xorg :0' >/dev/null 2>&1 && printf 1 || printf 0)"
beagle_stream_client_state="$(pgrep -x beagle-stream-client >/dev/null 2>&1 && printf 1 || printf 0)"
kiosk_state="$(pgrep -x beagle-kiosk >/dev/null 2>&1 && printf 1 || printf 0)"
openbox_state="$(pgrep -x openbox >/dev/null 2>&1 && printf 1 || printf 0)"
route_state="$(ip route show default 2>/dev/null | head -n 1 || true)"
drm_tail="$(journalctl -k -b --no-pager 2>/dev/null | tail -n 20 | tr '\n' ' ' | sed 's/[[:space:]]\\+/ /g' | cut -c1-800)"
last_trace="$(tail -n 1 "$TRACE_FILE" 2>/dev/null || true)"

{
  printf 'timestamp=%q\n' "$timestamp"
  printf 'xorg=%q\n' "$xorg_state"
  printf 'beagle-stream-client=%q\n' "$beagle_stream_client_state"
  printf 'kiosk=%q\n' "$kiosk_state"
  printf 'openbox=%q\n' "$openbox_state"
  printf 'default_route=%q\n' "$route_state"
  printf 'last_trace=%q\n' "$last_trace"
  printf 'kernel_tail=%q\n' "$drm_tail"
} >"$STATUS_FILE"

if declare -F sync_device_runtime_state >/dev/null 2>&1; then
  sync_device_runtime_state >/dev/null 2>&1 || true
fi

state_signature="xorg=${xorg_state};beagle-stream-client=${beagle_stream_client_state};kiosk=${kiosk_state};openbox=${openbox_state};route=${route_state}"
prev_signature="$(cat "$PREV_FILE" 2>/dev/null || true)"
if [[ "$state_signature" != "$prev_signature" ]]; then
  printf '[%s] phase=heartbeat %s\n' "$timestamp" "$state_signature" >>"$TRACE_FILE" 2>/dev/null || true
  printf '%s\n' "$state_signature" >"$PREV_FILE"
fi
