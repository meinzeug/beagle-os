{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Beagle OS control plane — HTTP, auth, rate limits, VM/session counts.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "HTTP request rate (per status class)",
      "type": "timeseries",
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (status) (rate(beagle_http_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "HTTP request latency (p50/p95/p99)",
      "type": "timeseries",
      "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(beagle_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(beagle_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(beagle_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "Auth failures (per kind)",
      "type": "timeseries",
      "id": 3,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (kind) (rate(beagle_auth_failures_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "Rate-limit drops (per path)",
      "type": "timeseries",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (path) (rate(beagle_rate_limit_drops_total[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "VM count",
      "type": "stat",
      "id": 5,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "targets": [{"expr": "beagle_vm_count", "refId": "A"}]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "Active sessions",
      "type": "stat",
      "id": 6,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "targets": [{"expr": "beagle_session_count", "refId": "A"}]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "title": "Process uptime",
      "type": "stat",
      "id": 7,
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "time() - beagle_process_start_time_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["beagle-os", "control-plane"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Beagle OS Control Plane",
  "uid": "beagle-control-plane",
  "version": 1
}
